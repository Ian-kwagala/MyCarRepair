<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyCarRepair | Trusted Mechanics Anytime Anywhere</title>
    <!-- Main CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/alerts.css">
    <!-- This line adds the icon to the browser tab -->
<link rel="icon" type="image/png" href="/images/favicon.png">
<script src="/js/alerts.js"></script>
</head>
<body>

    <!-- Hero Section -->
    <header class="hero">
        <div class="overlay">
            <nav class="top-nav">
                <div class="logo">MyCarRepair</div>
            </nav>

            <div class="hero-content">
                <span class="badge"><i data-lucide="shield-check"></i> Verified & Trusted Mechanics</span>
                <h1>Trusted Mechanics, <br><span class="highlight">Anytime, Anywhere.</span></h1>
                <p>Connect with certified mechanics near you. From emergency roadside help to scheduled maintenance — we've got your car covered.</p>
                
                <div class="hero-actions">
                    <a href="/login" class="btn-primary">I Need a Mechanic <i data-lucide="chevron-right"></i></a>
                    <a href="/login" class="btn-outline">I am a Mechanic <i data-lucide="wrench"></i></a>
                </div>

                <div class="stats">
                    <div class="stat-item">
                        <strong>2,500+</strong>
                        <span>Verified Mechanics</span>
                    </div>
                    <div class="stat-item">
                        <strong>50K+</strong>
                        <span>Jobs Completed</span>
                    </div>
                    <div class="stat-item">
                        <strong>&lt; 15 min</strong>
                        <span>Avg Response</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Bottom Navigation (One-Hand Operation) -->
    <nav class="bottom-nav">
        <a href="/" class="nav-item active">
            <i data-lucide="home"></i>
            <span>Home</span>
        </a>
        <a href="/login" class="nav-item">
            <i data-lucide="search"></i>
            <span>Find</span>
        </a>
        <a href="/login" class="nav-item">
            <i data-lucide="user"></i>
            <span>Profile</span>
        </a>
    </nav>

    <script>
        // Initialize Lucide Icons
        lucide.createIcons();
    </script>
    <!-- Include these at the bottom of your <body> -->
<link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
</body>
</html>