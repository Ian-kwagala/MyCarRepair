<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= car.plate_number %> | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
    <style>
        .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 20px; }
        .spec-card {
            background: white; border: 1.5px solid #e2e8f0; border-radius: 18px;
            padding: 15px; transition: 0.3s;
        }
        .spec-card:hover { border-color: var(--action-orange); transform: translateY(-3px); }
        .spec-label { font-size: 10px; font-weight: 800; color: #94a3b8; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px; display: block; }
        .spec-value { font-size: 15px; font-weight: 700; color: #1e293b; }
        
        .car-hero { height: 280px; width: 100%; position: relative; overflow: hidden; background: #0f172a; }
        .car-hero img { width: 100%; height: 100%; object-fit: cover; }
        .plate-badge {
            position: absolute; bottom: 20px; left: 20px; background: var(--action-orange);
            color: white; padding: 6px 15px; border-radius: 10px; font-weight: 900; font-size: 18px;
            box-shadow: 0 10px 20px rgba(249, 115, 22, 0.3);
        }
    </style>
</head>
<body style="background: #f8fafc; padding-bottom: 50px;">

    <!-- IMAGE HEADER -->
    <div class="car-hero">
        <% if(car.photos) { %>
            <img src="<%= car.photos.split(',')[0] %>" alt="Car Image">
        <% } else { %>
            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: white; opacity: 0.2;">
                <i data-lucide="image" size="64"></i>
            </div>
        <% } %>
        <div class="plate-badge"><%= car.plate_number %></div>
    </div>

    <!-- CAR TITLE -->
    <div style="padding: 25px 20px 10px 20px;">
        <h1 style="font-size: 28px; font-weight: 900; color: #0f172a; margin: 0;"><%= car.make %> <%= car.model %></h1>
        <p style="color: #64748b; font-weight: 600;"><i data-lucide="user" size="14"></i> Owned by <%= userName %></p>
    </div>

    <!-- TECHNICAL SPECS GRID -->
    <div class="details-grid">
        <div class="spec-card">
            <span class="spec-label">Mileage</span>
            <span class="spec-value"><%= (Number(car.mileage)).toLocaleString() %> Km</span>
        </div>
        <div class="spec-card">
            <span class="spec-label">Fuel Type</span>
            <span class="spec-value"><%= car.fuel_type || 'Not Set' %></span>
        </div>
        <div class="spec-card">
            <span class="spec-label">Transmission</span>
            <span class="spec-value"><%= car.transmission %></span>
        </div>
        <div class="spec-card">
            <span class="spec-label">Color</span>
            <span class="spec-value"><%= car.color || 'Not Set' %></span>
        </div>
        <div class="spec-card">
            <span class="spec-label">Tyre Size</span>
            <span class="spec-value"><%= car.tyre_size || 'N/A' %></span>
        </div>
        <div class="spec-card">
            <span class="spec-label">Year</span>
            <span class="spec-value"><%= car.year %></span>
        </div>
        <div class="spec-card" style="grid-column: span 2;">
            <span class="spec-label">Last Service Date</span>
            <span class="spec-value">
                <%= car.last_service_date ? new Date(car.last_service_date).toLocaleDateString('en-GB', {day:'numeric', month:'long', year:'numeric'}) : 'No record found' %>
            </span>
        </div>
    </div>

    <!-- ACTIONS -->
    <div style="padding: 10px 20px;">
        <button onclick="location.href='/owner/dashboard'" class="btn-outline" style="width: 100%; border-radius: 15px; margin-bottom: 15px; border-color: #cbd5e1;">
            Back to Garage
        </button>

        <div style="display: flex; gap: 10px;">
            <button onclick="location.href='/owner/car/<%= car.id %>/edit'" class="btn-outline" style="flex: 1; border-radius: 12px; display: flex; align-items: center; justify-content: center; gap: 8px;">
                <i data-lucide="edit-3" size="18"></i> Edit
            </button>
            
            <form action="/owner/car/<%= car.id %>/delete" method="POST" style="flex: 1;" onsubmit="return confirm('Delete this vehicle?')">
                <button type="submit" style="width: 100%; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; padding: 12px; border-radius: 12px; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;">
                    <i data-lucide="trash-2" size="18"></i> Delete
                </button>
            </form>
        </div>
    </div>

    <script>lucide.createIcons();</script>
</body>
</html>