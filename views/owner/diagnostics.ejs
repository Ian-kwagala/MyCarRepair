<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Diagnostics | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- This line adds the icon to the browser tab -->
<link rel="icon" type="image/png" href="/images/favicon.png">
    <link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const globalUserId = "<%= userId %>";
        if (globalUserId) {
            socket.emit('join_room', globalUserId);
        }
    </script>

    <style>
        /* LUXURY ANIMATIONS */
        @keyframes revealUp {
            from { opacity: 0; transform: translateY(25px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .reveal { animation: revealUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }
        .delay-4 { animation-delay: 0.4s; }

        /* SYMPTOM CARDS */
        .symptom-input { display: none; }
        .symptom-box {
            background: white; border: 2.5px solid #e2e8f0; border-radius: 20px;
            padding: 25px 15px; text-align: center; cursor: pointer; transition: 0.3s;
            display: flex; flex-direction: column; align-items: center; gap: 12px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }
        .symptom-box i { color: #94a3b8; transition: 0.3s; }
        .symptom-box span { font-weight: 600; font-size: 14px; color: #475569; }

        .symptom-input:checked + .symptom-box {
            border-color: var(--action-orange); background: #fff7ed;
            transform: scale(1.05); box-shadow: 0 10px 20px rgba(249, 115, 22, 0.15);
        }
        .symptom-input:checked + .symptom-box i { color: var(--action-orange); transform: rotate(10deg); }

        /* PHOTO UPLOAD PULSE */
        .photo-zone {
            border: 2px dashed #cbd5e1; border-radius: 20px; padding: 30px;
            text-align: center; background: white; cursor: pointer; transition: 0.3s;
            position: relative; overflow: hidden;
        }
        .photo-zone:hover { border-color: var(--action-orange); background: #fff7ed; }
        
        .pulse-icon {
            display: inline-flex; padding: 12px; background: #f1f5f9;
            border-radius: 50%; color: #64748b; margin-bottom: 10px;
            animation: softPulse 2s infinite;
        }
        @keyframes softPulse {
            0% { box-shadow: 0 0 0 0 rgba(100, 116, 139, 0.2); }
            70% { box-shadow: 0 0 0 15px rgba(100, 116, 139, 0); }
            100% { box-shadow: 0 0 0 0 rgba(100, 116, 139, 0); }
        }

        .input-elegant {
            width: 100%; padding: 15px; border-radius: 14px; border: 1.5px solid #e2e8f0;
            background: white; outline: none; font-size: 15px; transition: 0.3s;
        }
        .input-elegant:focus { border-color: var(--action-orange); box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1); }

        .camera-modal {
            position: fixed;
            inset: 0;
            background: rgba(2, 6, 23, 0.82);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 18px;
        }
        .camera-modal.active {
            display: flex;
        }
        .camera-panel {
            width: min(420px, 100%);
            background: #0f172a;
            border: 1px solid rgba(255, 255, 255, 0.14);
            border-radius: 18px;
            padding: 14px;
            color: #e2e8f0;
            box-shadow: 0 24px 48px rgba(2, 6, 23, 0.4);
        }
        .camera-live {
            width: 100%;
            max-height: 60vh;
            background: #020617;
            border-radius: 14px;
            object-fit: cover;
        }
        .camera-actions {
            margin-top: 12px;
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .camera-btn {
            border: none;
            border-radius: 12px;
            padding: 10px 14px;
            font-size: 12px;
            font-weight: 800;
            cursor: pointer;
        }
        .camera-btn.capture {
            background: #f97316;
            color: #ffffff;
        }
        .camera-btn.done {
            background: #16a34a;
            color: #ffffff;
        }
        .camera-btn.cancel {
            background: #334155;
            color: #f8fafc;
        }
        #diagCameraStatus {
            margin-top: 8px;
            text-align: center;
            font-size: 12px;
            color: #cbd5e1;
        }
    </style>

</head>
<body>
    <!-- Gradient Header -->
    <div style="background: linear-gradient(135deg, #0f172a 0%, #1e40af 100%); padding: 40px 20px; color: white; border-radius: 0 0 35px 35px; box-shadow: 0 10px 30px rgba(0,0,0,0.15);">
        <div style="display: flex; align-items: center; gap: 15px;">
            <a href="/owner/dashboard" style="color: white; background: rgba(255,255,255,0.1); padding: 8px; border-radius: 12px;"><i data-lucide="arrow-left" size="20"></i></a>
            <div>
                <h2 style="font-weight: 800; letter-spacing: -0.5px;">Vehicle Diagnostics</h2>
                <p style="opacity: 0.7; font-size: 13px;">Identify issues for a faster repair</p>
            </div>
        </div>
    </div>

    <div style="padding: 25px 20px;">
        <form id="diagnosticsForm" action="/owner/finalize-booking" method="POST" enctype="multipart/form-data">
            
            <label class="label-text reveal delay-1" style="font-weight: 700; margin-bottom: 15px; display: block;">STEP 1: SELECT SYMPTOMS</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 10px;">
                
                <label class="reveal delay-1">
                    <input type="checkbox" name="symptoms" value="Engine Light" class="symptom-input">
                    <div class="symptom-box"><i data-lucide="alert-octagon" size="32"></i><span>Engine Light</span></div>
                </label>

                <label class="reveal delay-2">
                    <input type="checkbox" name="symptoms" value="Strange Noise" class="symptom-input">
                    <div class="symptom-box"><i data-lucide="volume-2" size="32"></i><span>Strange Noise</span></div>
                </label>

                <label class="reveal delay-3">
                    <input type="checkbox" name="symptoms" value="Overheating" class="symptom-input">
                    <div class="symptom-box"><i data-lucide="thermometer-snowflake" size="32"></i><span>Overheating</span></div>
                </label>

                <label class="reveal delay-4">
                    <input type="checkbox" name="symptoms" value="Unusual Smoke" class="symptom-input">
                    <div class="symptom-box"><i data-lucide="wind" size="32"></i><span>Unusual Smoke</span></div>
                </label>
            </div>

            <!-- PHOTO SECTION -->
            <div class="reveal delay-3" style="margin-top: 35px;">
                <label class="label-text" style="font-weight: 700; display: block; margin-bottom: 12px;">STEP 2: ADD VISUAL PROOF</label>
                <div class="photo-zone" style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 220px; min-height: 120px; margin-bottom: 10px;">
                    <div class="pulse-icon"><i data-lucide="camera" size="28"></i></div>
                    <div style="display: flex; gap: 8px; margin-top: 4px; flex-wrap: wrap; justify-content: center;">
                        <button type="button" onclick="triggerDiagnosticPhotoSource('gallery')" style="border: none; background: #f1f5f9; color: #1e293b; padding: 8px 10px; border-radius: 10px; font-size: 11px; font-weight: 700; cursor: pointer;">Upload</button>
                        <button type="button" onclick="triggerDiagnosticPhotoSource('camera')" style="border: none; background: #f97316; color: #ffffff; padding: 8px 10px; border-radius: 10px; font-size: 11px; font-weight: 700; cursor: pointer;">Take Photo</button>
                    </div>
                    <input type="file" id="diag_photo_gallery" name="diag_photo" accept="image/*" style="display: none;">
                    <input type="file" id="diag_photo_camera" name="diag_photo" accept="image/*" capture="environment" style="display: none;">
                </div>
                <div id="photo-preview" style="margin-top: 10px;"></div>
                <h4 style="color: #1e293b; margin-top: 0;">Snap the Dashboard</h4>
                <p style="font-size: 12px; color: #94a3b8; margin-top: 4px;">Helps mechanics prepare the right tools</p>
            </div>

            <!-- CAR SELECTION -->
            <div class="reveal delay-4" style="margin-top: 35px;">
                <label class="label-text" style="font-weight: 700; display: block; margin-bottom: 12px;">STEP 3: CHOOSE VEHICLE</label>
                <div style="position: relative; display: flex; align-items: center;">
                    <i data-lucide="car" size="18" style="position: absolute; left: 15px; color: #94a3b8;"></i>
                    <select name="vehicle_id" class="input-elegant" style="padding-left: 45px;" required>
                        <% if (cars.length === 0) { %>
                            <option disabled selected>Please add a car in your garage first</option>
                        <% } else { %>
                            <!-- If only 1 car, this option becomes 'selected' automatically -->
                            <% cars.forEach(car => { %>
                                <option value="<%= car.id %>" <%= cars.length === 1 ? 'selected' : '' %>>
                                    <%= car.make %> <%= car.model %> (<%= car.plate_number %>)
                                </option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
            </div>

            <!-- Hidden booking fields for auto-dispatch -->
            <input type="hidden" name="service_type" value="Diagnostic Scan">
            <input type="hidden" name="scheduled_date" value="Immediate">

            <button type="submit" class="btn-primary reveal delay-4" style="width: 100%; margin-top: 40px; padding: 20px; border-radius: 20px; font-size: 16px; font-weight: 700; box-shadow: 0 15px 30px rgba(249, 115, 22, 0.3);">
                Send Diagnostic Request <i data-lucide="zap" size="18" style="margin-left: 8px;"></i>
            </button>
        </form>
    </div>

    <div id="diagCameraModal" class="camera-modal" aria-hidden="true">
        <div class="camera-panel">
            <video id="diagCameraVideo" class="camera-live" autoplay playsinline muted></video>
            <div id="diagCameraStatus">Camera ready. Capture your dashboard photo.</div>
            <div class="camera-actions">
                <button type="button" id="diagCaptureBtn" class="camera-btn capture">Capture Photo</button>
                <button type="button" id="diagDoneBtn" class="camera-btn done">Done</button>
                <button type="button" id="diagCancelBtn" class="camera-btn cancel">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        const diagnosticsForm = document.getElementById('diagnosticsForm');
        const diagPhotoGallery = document.getElementById('diag_photo_gallery');
        const diagPhotoCamera = document.getElementById('diag_photo_camera');
        const diagCameraModal = document.getElementById('diagCameraModal');
        const diagCameraVideo = document.getElementById('diagCameraVideo');
        const diagCameraStatus = document.getElementById('diagCameraStatus');
        const diagCaptureBtn = document.getElementById('diagCaptureBtn');
        const diagDoneBtn = document.getElementById('diagDoneBtn');
        const diagCancelBtn = document.getElementById('diagCancelBtn');

        let activeDiagStream = null;
        let capturedDiagFile = null;

        function showPreview(file) {
            const preview = document.getElementById('photo-preview');
            preview.innerHTML = '';
            if (file) {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.style.maxWidth = '120px';
                img.style.maxHeight = '120px';
                img.style.borderRadius = '12px';
                img.style.boxShadow = '0 2px 8px rgba(0,0,0,0.08)';
                img.style.marginTop = '8px';
                preview.appendChild(img);
            }
        }

        function closeDiagCameraModal() {
            diagCameraModal.classList.remove('active');
            diagCameraModal.setAttribute('aria-hidden', 'true');
            if (activeDiagStream) {
                activeDiagStream.getTracks().forEach((track) => track.stop());
                activeDiagStream = null;
            }
            diagCameraVideo.srcObject = null;
        }

        async function openDiagCameraModal() {
            if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                diagPhotoCamera.click();
                return;
            }

            try {
                activeDiagStream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: { ideal: 'environment' } },
                    audio: false
                });
                diagCameraVideo.srcObject = activeDiagStream;
                diagCameraModal.classList.add('active');
                diagCameraModal.setAttribute('aria-hidden', 'false');
                diagCameraStatus.textContent = 'Camera ready. Capture your dashboard photo.';
            } catch (error) {
                alert('Camera access was blocked. Please allow camera permission, then try again.');
            }
        }

        function captureDiagPhoto() {
            if (!diagCameraVideo.videoWidth || !diagCameraVideo.videoHeight) return;

            const canvas = document.createElement('canvas');
            canvas.width = diagCameraVideo.videoWidth;
            canvas.height = diagCameraVideo.videoHeight;
            const context = canvas.getContext('2d');
            context.drawImage(diagCameraVideo, 0, 0, canvas.width, canvas.height);

            canvas.toBlob((blob) => {
                if (!blob) return;
                capturedDiagFile = new File([blob], `diagnostic-${Date.now()}.jpg`, { type: 'image/jpeg' });
                const transfer = new DataTransfer();
                transfer.items.add(capturedDiagFile);
                diagPhotoCamera.files = transfer.files;
                showPreview(capturedDiagFile);
                diagCameraStatus.textContent = 'Photo captured. Tap Done to continue.';
            }, 'image/jpeg', 0.9);
        }

        function triggerDiagnosticPhotoSource(source) {
            if (source === 'camera') {
                openDiagCameraModal();
                return;
            }
            diagPhotoGallery.click();
        }

        window.triggerDiagnosticPhotoSource = triggerDiagnosticPhotoSource;

        diagPhotoGallery.addEventListener('change', (event) => {
            if (event.target.files && event.target.files[0]) {
                showPreview(event.target.files[0]);
            }
        });

        diagPhotoCamera.addEventListener('change', (event) => {
            if (event.target.files && event.target.files[0]) {
                showPreview(event.target.files[0]);
            }
        });

        diagCaptureBtn.addEventListener('click', captureDiagPhoto);
        diagDoneBtn.addEventListener('click', closeDiagCameraModal);
        diagCancelBtn.addEventListener('click', closeDiagCameraModal);

        diagnosticsForm.addEventListener('submit', (event) => {
            const hasGalleryFile = diagPhotoGallery.files && diagPhotoGallery.files.length > 0;
            const hasCameraFile = diagPhotoCamera.files && diagPhotoCamera.files.length > 0;
            if (!hasGalleryFile && !hasCameraFile) {
                event.preventDefault();
                alert('Please upload or take a diagnostic photo before submitting.');
            }
        });

        window.addEventListener('beforeunload', closeDiagCameraModal);

        lucide.createIcons();
    </script>
    <!-- Include these at the bottom of your <body> -->
<link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
<%- include('../partials/alerts') %>
</body>
</html>