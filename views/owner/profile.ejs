<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/alerts.css">
    <!-- This line adds the icon to the browser tab -->
<link rel="icon" type="image/png" href="/images/favicon.png">
<script src="/js/alerts.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const globalUserId = "<%= userId %>";
        if (globalUserId) {
            socket.emit('join_room', globalUserId);
        }
    </script>
    <style>
        /* PROFESSIONAL SPRING ANIMATIONS */
        @keyframes springUp {
            0% { transform: translateY(40px); opacity: 0; }
            70% { transform: translateY(-5px); }
            100% { transform: translateY(0); opacity: 1; }
        }
        .animate-spring { animation: springUp 0.7s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }
        .delay-4 { animation-delay: 0.4s; }

        /* LUXURY PROFILE COMPONENTS */
        .profile-container {
            background: white; border-radius: 30px; padding: 30px; margin-top: 60px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15); border: 1px solid rgba(255,255,255,0.3);
        }
        
        .avatar-ring {
            width: 110px; height: 110px; background: var(--white);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            margin: -85px auto 20px auto; box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            position: relative;
        }
        .avatar-content {
            width: 95px; height: 95px; background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            color: white; font-size: 40px; font-weight: 800; border: 3px solid white;
        }

        .stat-card {
            background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 20px;
            padding: 18px; text-align: center; flex: 1; transition: 0.3s;
        }
        .stat-card:hover { border-color: var(--action-orange); background: #fff7ed; }

        .form-label {
            font-size: 11px; font-weight: 800; color: #94a3b8;
            letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 8px; display: block;
        }

        .input-elegant-group {
            background: #f8fafc; border: 2px solid #e2e8f0; border-radius: 16px;
            display: flex; align-items: center; padding: 4px 16px; margin-bottom: 20px;
            transition: all 0.3s ease;
        }
        .input-elegant-group:focus-within {
            border-color: var(--action-orange); background: white;
            box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.1);
            transform: translateY(-2px);
        }
        .input-elegant-group input {
            border: none; background: transparent; padding: 12px; width: 100%;
            font-size: 15px; font-weight: 600; color: #1e293b; outline: none;
        }

        .btn-logout {
            background: #fff1f2; color: #e11d48; border: 1.5px solid #ffe4e6;
            width: 100%; padding: 18px; border-radius: 18px; font-weight: 800;
            margin-top: 15px; cursor: pointer; transition: 0.3s;
        }
        .btn-logout:hover { background: #ffe4e6; transform: translateY(-2px); }
    </style>
</head>
<body>

    <div class="page-bg"></div><div class="bg-overlay"></div>

    <!-- Animated Header -->
    <div style="background: var(--primary-blue); padding: 45px 25px 100px 25px; color: white; display: flex; align-items: center; gap: 20px;">
        <button onclick="location.href='/owner/dashboard'" style="color: white; background: rgba(255,255,255,0.1); border:none; padding: 10px; border-radius: 14px; display: flex; cursor: pointer;">
            <i data-lucide="arrow-left" size="22"></i>
        </button>
        <h2 style="font-weight: 900; letter-spacing: -1px; margin: 0; font-size: 24px;">Profile Settings</h2>
    </div>

    <div style="padding: 0 20px;">
        <div class="profile-container animate-spring">
            
            <!-- AVATAR SECTION -->
            <div class="avatar-ring animate-spring delay-1">
                <div class="avatar-content"><%= user.full_name.charAt(0) %></div>
            </div>
            
            <div class="animate-spring delay-2" style="text-align: center; margin-bottom: 30px;">
                <h2 style="color: #1e293b; font-weight: 800; margin-bottom: 5px;"><%= user.full_name %></h2>
                <p style="color: #64748b; font-size: 14px; font-weight: 500;"><%= user.email %></p>
            </div>

            <!-- ACHIEVEMENTS STATS -->
            <div style="display: flex; gap: 15px; margin-bottom: 35px;" class="animate-spring delay-2">
                <div class="stat-card">
                    <p style="font-size: 10px; font-weight: 800; color: #94a3b8; margin-bottom: 5px;">VEHICLES</p>
                    <strong style="font-size: 22px; color: var(--primary-blue);"><%= stats.cars %></strong>
                </div>
                <div class="stat-card">
                    <p style="font-size: 10px; font-weight: 800; color: #94a3b8; margin-bottom: 5px;">JOBS DONE</p>
                    <strong style="font-size: 22px; color: var(--action-orange);"><%= stats.jobs %></strong>
                </div>
            </div>

            <!-- EDITABLE FORM -->
            <form action="/owner/profile/update" method="POST" class="animate-spring delay-3">
                <span class="form-label">Account Name</span>
                <div class="input-elegant-group">
                    <i data-lucide="user" size="18" color="#94a3b8"></i>
                    <input type="text" name="full_name" value="<%= user.full_name %>" required>
                </div>

                <span class="form-label">Phone Connection</span>
                <div class="input-elegant-group">
                    <i data-lucide="phone" size="18" color="#94a3b8"></i>
                    <input type="text" name="phone" value="<%= user.phone %>" required>
                </div>

                <button type="submit" class="btn-primary" style="width: 100%; margin-top: 15px; padding: 20px; border-radius: 20px; font-size: 16px; font-weight: 800; box-shadow: 0 15px 30px rgba(249, 115, 22, 0.3);">
                    Save Changes <i data-lucide="save" size="18" style="margin-left: 8px;"></i>
                </button>
            </form>

            <div class="animate-spring delay-4">
                <button onclick="location.href='/logout'" class="btn-logout">
                    Sign Out <i data-lucide="log-out" size="18" style="margin-left: 8px;"></i>
                </button>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
    <!-- Include these at the bottom of your <body> -->
<link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
<%- include('../partials/alerts') %>
</body>
</html>