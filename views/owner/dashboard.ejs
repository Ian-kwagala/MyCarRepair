<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/alert.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/socket.io/socket.io.js"></script>
    <!-- This line adds the icon to the browser tab -->
<link rel="icon" type="image/png" href="/images/favicon.png">
    <script>
        const socket = io();
        const globalUserId = "<%= userId %>";
        if (globalUserId) {
            socket.emit('join_room', globalUserId);
            console.log('Owner joined private room:', globalUserId);
        }
    </script>
    <script src="/js/alert.js"></script>
    <style>
        /* PROFESSIONAL ANIMATIONS */
        @keyframes slideFadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-item { animation: slideFadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }
        .delay-4 { animation-delay: 0.4s; }

        .header-gradient {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: white;
            padding: 40px 20px 30px 20px;
            border-radius: 0 0 35px 35px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .action-card {
            border-radius: 20px;
            padding: 22px;
            transition: all 0.3s ease;
            cursor: pointer;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
        }
        .action-card:active { transform: scale(0.96); }

        .profile-trigger {
            background: rgba(255,255,255,0.1);
            padding: 10px;
            border-radius: 15px;
            border: 1px solid rgba(255,255,255,0.1);
            transition: 0.3s;
        }
        .profile-trigger:hover { background: rgba(255,255,255,0.2); }
    </style>
</head>
<body>
    <!-- DYNAMIC HEADER -->
    <header class="header-gradient animate-item">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <p id="dynamic-greeting" style="opacity: 0.7; font-size: 14px; font-weight: 500;">Good morning 👋</p>
                <h2 style="font-size: 26px; font-weight: 800; margin: 4px 0;"><%= userName %></h2>
            </div>
            <!-- Profile Icon Link -->
            <a href="/owner/profile" class="profile-trigger">
                <i data-lucide="user-circle" size="24" color="white"></i>
            </a>
        </div>
        
        <div style="margin-top: 20px; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.05); padding: 12px 15px; border-radius: 16px;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <i data-lucide="map-pin" size="14" color="var(--action-orange)"></i>
                <span id="current-location" style="font-size: 12px; opacity: 0.8; font-weight: 600;">Detecting location...</span>
            </div>
            <div style="font-size: 12px; font-weight: 800; color: var(--action-orange); letter-spacing: 1px;" id="live-clock">
                00:00:00
            </div>
        </div>
    </header>

    <div style="padding: 25px 20px;">
        <h4 style="color: #64748b; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px;">What do you need today?</h4>
        
        <!-- GRID LAYOUT -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            
            <!-- EMERGENCY SOS -->
            <div onclick="location.href='./sos'" class="action-card animate-item delay-1" style="grid-column: span 2; background: #ef4444; color: white;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <i data-lucide="alert-circle" size="24" style="margin-bottom: 10px;"></i>
                        <h4 style="font-size: 18px;">Emergency SOS</h4>
                        <p style="font-size: 12px; opacity: 0.9;">Towing, flat tire, battery jump</p>
                    </div>
                    <i data-lucide="chevron-right" size="20" opacity="0.5"></i>
                </div>
            </div>

            <!-- BOOK MAINTENANCE -->
            <div onclick="location.href='/owner/book-maintenance'" class="action-card animate-item delay-2" style="background: white; border: 1px solid #e2e8f0;">
                <i data-lucide="calendar" size="24" color="#1e293b"></i>
                <h4 style="margin-top: 12px; color: #1e293b;">Book Service</h4>
                <p style="font-size: 11px; color: #64748b;">Oil change, tune-up</p>
            </div>

            <!-- DIAGNOSTICS -->
            <div onclick="location.href='/owner/diagnostics'" class="action-card animate-item delay-3" style="background: white; border: 1px solid #e2e8f0;">
                <i data-lucide="activity" size="24" color="#1e293b"></i>
                <h4 style="margin-top: 12px; color: #1e293b;">Diagnostics</h4>
                <p style="font-size: 11px; color: #64748b;">Engine check, codes</p>
            </div>

            <!-- SPARE PARTS -->
            <div class="action-card animate-item delay-4" style="grid-column: span 2; background: #f97316; color: white;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <i data-lucide="package" size="24" style="margin-bottom: 10px;"></i>
                        <h4 style="font-size: 18px;">Spare Parts</h4>
                        <p style="font-size: 12px; opacity: 0.9;">OEM & aftermarket accessories</p>
                    </div>
                    <i data-lucide="chevron-right" size="20" opacity="0.5"></i>
                </div>
            </div>
        </div>

        <!-- MY GARAGE -->
        <div style="margin-top: 35px;" class="animate-item delay-4">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                <h4 style="color: #1e293b; font-weight: 800;">My Garage</h4>
                <a href="/owner/add-car" style="color: #f97316; font-size: 13px; font-weight: 800; text-decoration: none;">+ ADD CAR</a>
            </div>
            
            <% if (cars && cars.length > 0) { %>
                <% cars.forEach(car => { %>
                    <div onclick="location.href='/owner/car/<%= car.id %>'" style="background: white; border-radius: 20px; padding: 12px; display: flex; align-items: center; border: 1px solid #e2e8f0; margin-bottom: 12px;">
                        <div style="width: 50px; height: 50px; background: #f1f5f9; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                            <i data-lucide="car" color="#64748b"></i>
                        </div>
                        <div style="flex: 1;">
                            <h5 style="margin: 0; color: #1e293b;"><%= car.make %> <%= car.model %></h5>
                            <p style="font-size: 12px; color: #94a3b8;"><%= car.plate_number %> • <%= car.transmission %></p>
                        </div>
                        <i data-lucide="chevron-right" size="18" color="#cbd5e1"></i>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="padding: 30px; border: 2px dashed #e2e8f0; border-radius: 20px; text-align: center; color: #94a3b8;">
                    <i data-lucide="image" size="32" style="margin-bottom: 10px;"></i>
                    <p style="font-size: 13px;">No vehicles found</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- BOTTOM NAVIGATION (Cleaned up) -->
    <nav class="bottom-nav">
        <a href="/owner/dashboard" class="nav-item active">
            <i data-lucide="layout-dashboard"></i>
            <span>Dashboard</span>
        </a>
        <a href="/owner/activity" class="nav-item">
            <i data-lucide="clock"></i>
            <span>Activity</span>
        </a>
        <a href="/logout" class="nav-item">
            <i data-lucide="log-out"></i>
            <span>Logout</span>
        </a>
    </nav>

    <script>
        lucide.createIcons();
        const currentUserId = '<%= userId %>';

        // Socket listener for when mechanic accepts job
        socket.on('job_taken', (data) => {
            if (data.ownerId == currentUserId) {
                AppAlert.show(
                    "Mechanic Found!", 
                    `${data.mechanicName} is on the way to help you.`, 
                    "success",
                    () => { location.href = '/owner/track-job/' + data.jobId; }
                );
            }
        });

        // Socket listener for appointment responses (accept/decline)
        socket.on('appointment_update', (data) => {
            const type = data.decision === 'accepted' ? 'success' : 'warning';
            const msg = data.decision === 'accepted' ? 
                `Mechanic ${data.mechanicName} has confirmed your booking!` : 
                `Mechanic ${data.mechanicName} is unavailable. Please try another.`;

            AppAlert.show("Booking Update", msg, type, () => {
                location.href = '/owner/activity'; // Take them to see the updated status
            });
        });

        socket.on('job_progress_update', (data) => {
            AppAlert.show('Live Update', data.message || 'Your job status has changed.', 'info', () => {
                location.href = '/owner/track-job/' + data.jobId;
            });
        });

        // 1. DYNAMIC GREETING & CLOCK
        function updateStatus() {
            const now = new Date();
            const hours = now.getHours();
            let greeting = "Good evening 🌙";
            if (hours < 12) greeting = "Good morning ☀️";
            else if (hours < 18) greeting = "Good afternoon 🌤️";
            
            document.getElementById('dynamic-greeting').innerText = greeting;
            document.getElementById('live-clock').innerText = now.toLocaleTimeString('en-GB');
        }
        setInterval(updateStatus, 1000);
        updateStatus();

        // 2. REAL-TIME LOCATION
        async function updateOwnerLocation(lat, lng) {
            try {
                await fetch('/api/owner/update-location', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lat, lng })
                });
            } catch (err) {
                console.error('Failed to sync owner location:', err);
            }
        }

        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(position => {
                // For a real app, you'd use a Reverse Geocoding API here.
                // For now, let's show they are in the detected city area.
                document.getElementById('current-location').innerText = "Kampala Central, Uganda";
                updateOwnerLocation(position.coords.latitude, position.coords.longitude);
            }, () => {
                document.getElementById('current-location').innerText = "Kampala, Uganda";
            });
        }
    </script>

    <!-- RATING MODAL (Appears after job finish) -->
    <div id="finish-modal" class="alert-overlay" style="display: none;">
        <div class="alert-card animate-pop-in">
            <div style="color: #fbbf24;"><i data-lucide="star" size="48" fill="#fbbf24"></i></div>
            <h3 style="margin: 15px 0 5px 0;">Rate Your Experience</h3>
            <p>How was the service provided by your mechanic?</p>

            <!-- Interactive Stars -->
            <div style="display: flex; justify-content: center; gap: 8px; margin: 20px 0;">
                <% for(let i=1; i<=5; i++) { %>
                    <i data-lucide="star" class="star-btn" data-rating="<%= i %>" id="star-<%= i %>" style="cursor: pointer; color: #cbd5e1;"></i>
                <% } %>
            </div>

            <textarea id="rating-feedback" placeholder="Optional: Tell us what you liked or what could be better..." 
                      style="width: 100%; border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 12px; font-family: inherit; height: 80px; outline: none; margin-bottom: 20px;"></textarea>

            <button onclick="submitRating()" class="btn-primary" style="width: 100%;">Submit & Close</button>
        </div>
    </div>

    <!-- UPDATED GLOBAL SOS MODAL -->
    <div id="global-sos-modal" class="alert-overlay" style="display: none; align-items: center; justify-content: center;">
        <div class="alert-card animate-pop-in" style="position: relative;">

            <!-- THE NEW "X" CLOSE BUTTON -->
            <button onclick="closeSOSPopup()" style="position: absolute; top: 15px; right: 15px; background: #f1f5f9; border: none; border-radius: 50%; width: 30px; height: 30px; cursor: pointer; color: #64748b;">
                <i data-lucide="x" size="16"></i>
            </button>

            <div style="color: var(--emergency-red); margin-top: 10px;">
                <i data-lucide="bell-ring" size="48" class="animate-bounce"></i>
            </div>

            <h2 style="margin: 15px 0;">New SOS!</h2>
            <p id="sos-pop-details" style="font-weight: 700; color: #1e293b;"></p>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 25px;">
                <button onclick="closeSOSPopup()" class="btn-outline" style="border-radius: 12px;">Later</button>
                <button id="sos-pop-accept-btn" class="btn-primary" style="background: var(--emergency-red); border-radius: 12px;">Accept</button>
            </div>
        </div>
    </div>

    <script>
        let selectedStars = 0;
        let currentActiveJobId = null;

        // Owner dashboard does not manage mechanic duty state; default to online for popup behavior.
        const isOnline = true;

        socket.on('job_finished', (data) => {
            if (data.ownerId == currentUserId) {
                currentActiveJobId = data.jobId;
                document.getElementById('finish-modal').style.display = 'flex';
            }
        });

        document.querySelectorAll('.star-btn').forEach((star) => {
            star.addEventListener('click', () => {
                selectRating(Number(star.dataset.rating));
            });
        });

        function selectRating(n) {
            selectedStars = n;
            for(let i=1; i<=5; i++) {
                const star = document.getElementById(`star-${i}`);
                star.style.color = (i <= n) ? "#fbbf24" : "#cbd5e1";
                star.setAttribute('fill', (i <= n) ? "#fbbf24" : "none");
            }
        }

        async function submitRating() {
            if(selectedStars === 0) return AppAlert.show("Required", "Please select a star rating", "warning");

            const feedback = document.getElementById('rating-feedback').value;
            await fetch('/api/owner/rate-mechanic', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ jobId: currentActiveJobId, rating: selectedStars, feedback: feedback })
            });

            location.reload(); // Refresh to clean dashboard
        }

        function closeSOSPopup() {
            // Just hides the modal. The job stays in the list/workflow for later.
            document.getElementById('global-sos-modal').style.display = 'none';
        }

        function renderJobCard(job, containerId) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const item = document.createElement('div');
            item.style.display = 'none';
            item.dataset.jobId = job.id;
            container.appendChild(item);
        }

        function acceptJob(jobId, ownerId) {
            window.location.href = '/owner/track-job/' + jobId;
        }

        socket.on('new_job_pushed', (job) => {
            if (!isOnline) return;

            document.getElementById('sos-pop-details').innerText = `${job.owner_name} • ${job.service_type}`;
            document.getElementById('sos-pop-accept-btn').onclick = () => acceptJob(job.id, job.owner_id);

            document.getElementById('global-sos-modal').style.display = 'flex';
            lucide.createIcons(); // Draw the 'X' icon

            // The job still gets added to the list in the background
            renderJobCard(job, 'dynamic-sos-container');
        });
    </script>
    <!-- Include these at the bottom of your <body> -->
<link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
<%- include('../partials/alerts') %>
</body>
</html>