<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register Vehicle | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <link rel="stylesheet" href="/css/alerts.css">
    <script src="/js/alerts.js"></script>
    <script src="/socket.io/socket.io.js"></script>

    <script>
        const socket = io();
        const globalUserId = "<%= userId %>";
        if (globalUserId) {
            socket.emit('join_room', globalUserId);
        }
    </script>
    
    <style>
        body {
            background:
                radial-gradient(900px 450px at 50% -120px, rgba(249, 115, 22, 0.35), rgba(249, 115, 22, 0) 62%),
                linear-gradient(180deg, #0f172a 0%, #1e293b 38%, #f8fafc 38%, #f8fafc 100%);
            min-height: 100vh;
        }

        .page-hero {
            position: relative;
            padding: 56px 20px 72px 20px;
            text-align: center;
            color: #ffffff;
            overflow: hidden;
            animation: riseFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .page-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(110deg, transparent 40%, rgba(255,255,255,0.08) 50%, transparent 60%);
            transform: translateX(-120%);
            animation: heroShine 4s ease-in-out infinite;
            pointer-events: none;
        }

        .hero-title {
            font-size: 32px;
            font-weight: 900;
            letter-spacing: -0.4px;
            margin: 0;
            text-shadow: 0 8px 24px rgba(2, 6, 23, 0.35);
        }

        .hero-subtitle {
            opacity: 0.8;
            font-size: 14px;
            margin-top: 8px;
        }

        .form-container {
            background: rgba(255, 255, 255, 0.96);
            border-radius: 30px;
            margin-top: -34px;
            padding: 26px 20px 30px 20px;
            border: 1px solid rgba(255, 255, 255, 0.8);
            box-shadow: 0 -8px 28px rgba(15, 23, 42, 0.08), 0 22px 44px rgba(15, 23, 42, 0.09);
            backdrop-filter: blur(6px);
        }

        .form-section {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            padding: 16px 14px;
            margin-bottom: 14px;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04);
            animation: riseFade 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .delay-1 { animation-delay: 0.05s; }
        .delay-2 { animation-delay: 0.12s; }
        .delay-3 { animation-delay: 0.2s; }
        .delay-4 { animation-delay: 0.28s; }

        .section-title {
            font-size: 11px;
            font-weight: 900;
            color: #64748b;
            letter-spacing: 1.6px;
            text-transform: uppercase;
            margin-bottom: 12px;
            display: block;
        }

        .grid-two {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .input-box {
            background: #f8fafc;
            border: 1.5px solid #e2e8f0;
            border-radius: 14px;
            padding: 12px 14px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
        }

        .input-box:hover {
            transform: translateY(-1px);
            border-color: #cbd5e1;
        }

        .input-box:focus-within {
            border-color: var(--action-orange);
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.12);
        }

        .input-box input,
        .input-box select {
            border: none;
            background: transparent;
            width: 100%;
            outline: none;
            font-size: 15px;
            font-weight: 600;
            color: #0f172a;
        }

        .input-box input::placeholder {
            color: #64748b;
            font-weight: 600;
        }

        .photo-upload-zone {
            border: 2px dashed #cbd5e1;
            border-radius: 18px;
            text-align: center;
            cursor: pointer;
            background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
            padding: 24px 14px;
            transition: border-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
        }

        .photo-upload-zone:hover {
            border-color: var(--action-orange);
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
        }

        #preview-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 16px;
        }

        .preview-img {
            width: 100%;
            aspect-ratio: 1;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            animation: zoomIn 0.28s ease-out;
        }

        .submit-btn {
            width: 100%;
            margin-top: 16px;
            padding: 18px;
            border-radius: 16px;
            font-weight: 900;
            letter-spacing: 0.3px;
            background: linear-gradient(90deg, #f97316 0%, #fb923c 100%);
            box-shadow: 0 12px 26px rgba(249, 115, 22, 0.32);
            transition: transform 0.22s ease, box-shadow 0.22s ease;
            animation: riseFade 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
            animation-delay: 0.35s;
        }

        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 30px rgba(249, 115, 22, 0.38);
        }

        .helper-text {
            font-size: 11px;
            color: #64748b;
            margin-top: 8px;
        }

        .camera-modal {
            position: fixed;
            inset: 0;
            background: rgba(2, 6, 23, 0.82);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 18px;
        }

        .camera-modal.active {
            display: flex;
        }

        .camera-panel {
            width: min(440px, 100%);
            background: #0f172a;
            border: 1px solid rgba(255, 255, 255, 0.14);
            border-radius: 18px;
            padding: 14px;
            color: #e2e8f0;
            box-shadow: 0 24px 48px rgba(2, 6, 23, 0.4);
        }

        .camera-live {
            width: 100%;
            max-height: 60vh;
            background: #020617;
            border-radius: 14px;
            object-fit: cover;
        }

        .camera-actions {
            margin-top: 12px;
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .camera-btn {
            border: none;
            border-radius: 12px;
            padding: 10px 14px;
            font-size: 12px;
            font-weight: 800;
            cursor: pointer;
        }

        .camera-btn.capture {
            background: #f97316;
            color: #ffffff;
        }

        .camera-btn.done {
            background: #16a34a;
            color: #ffffff;
        }

        .camera-btn.cancel {
            background: #334155;
            color: #f8fafc;
        }

        #camera-status {
            margin-top: 8px;
            text-align: center;
            font-size: 12px;
            color: #cbd5e1;
        }

        @keyframes riseFade {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes zoomIn {
            from { opacity: 0; transform: scale(0.92); }
            to { opacity: 1; transform: scale(1); }
        }

        @keyframes heroShine {
            0%, 100% { transform: translateX(-120%); }
            45%, 60% { transform: translateX(120%); }
        }

        @media (max-width: 560px) {
            .grid-two {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .hero-title {
                font-size: 28px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/back-nav') %>

    <div class="page-hero">
        <h2 class="hero-title">Register Vehicle</h2>
        <p class="hero-subtitle">Essential for emergency and maintenance accuracy</p>
    </div>

    <div class="form-container">
        <form id="addCarForm" action="/owner/add-car" method="POST" enctype="multipart/form-data">

            <div class="form-section delay-1">
                <span class="section-title">Identity</span>
                <div class="grid-two">
                    <div class="input-box"><input type="text" name="make" placeholder="Make (Toyota)" required></div>
                    <div class="input-box"><input type="text" name="model" placeholder="Model (Wish)" required></div>
                </div>
                <div class="grid-two">
                    <div class="input-box"><input type="text" name="plate" placeholder="Plate No." required></div>
                    <div class="input-box"><input type="number" name="year" placeholder="Year" value="2025" required></div>
                </div>
            </div>

            <div class="form-section delay-2">
                <span class="section-title">Technical Specs</span>
                <div class="grid-two">
                    <div class="input-box">
                        <select name="fuel_type" required>
                            <option value="" disabled selected>Fuel Type</option>
                            <option value="Petrol">Petrol</option>
                            <option value="Diesel">Diesel</option>
                            <option value="Hybrid">Hybrid</option>
                            <option value="Electric">Electric</option>
                        </select>
                    </div>
                    <div class="input-box"><input type="text" name="tyre_size" placeholder="Tyre Size (e.g. 195/65R15)"></div>
                </div>

                <div class="grid-two">
                    <div class="input-box">
                        <select name="transmission">
                            <option value="Automatic">Automatic</option>
                            <option value="Manual">Manual</option>
                        </select>
                    </div>
                    <div class="input-box"><input type="text" name="color" placeholder="Color"></div>
                </div>
            </div>

            <div class="form-section delay-3">
                <span class="section-title">Status</span>
                <div class="input-box">
                    <i data-lucide="gauge" size="18" color="#94a3b8"></i>
                    <input type="number" name="mileage" placeholder="Current Mileage (Km)">
                </div>
                <div class="input-box">
                    <i data-lucide="calendar" size="18" color="#94a3b8"></i>
                    <input type="text" name="last_service" onfocus="(this.type='date')" placeholder="Last Service Date">
                </div>
            </div>

            <div class="form-section delay-4">
                <span class="section-title">Visuals</span>
                <div class="photo-upload-zone">
                    <i data-lucide="camera" size="32" color="#94a3b8"></i>
                    <p style="font-size: 12px; color: #64748b; font-weight: 700; margin-top: 8px;">Choose how to add car photos</p>
                    <p class="helper-text">Upload multiple clear angles for faster mechanic diagnostics.</p>
                    <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-top: 10px;">
                        <button type="button" onclick="triggerCarPhotoSource('gallery')" style="border: none; background: #f1f5f9; color: #1e293b; padding: 9px 12px; border-radius: 10px; font-size: 12px; font-weight: 700; cursor: pointer;">Upload from Gallery</button>
                        <button type="button" onclick="triggerCarPhotoSource('camera')" style="border: none; background: #f97316; color: white; padding: 9px 12px; border-radius: 10px; font-size: 12px; font-weight: 700; cursor: pointer;">Take Photo</button>
                    </div>
                    <input type="file" name="car_photos" id="car_photos_gallery" multiple accept="image/*" style="display: none;">
                    <input type="file" name="car_photos" id="car_photos_camera" accept="image/*" capture="environment" style="display: none;">
                    <div id="preview-grid"></div>
                </div>
            </div>

            <button type="submit" class="btn-primary submit-btn">
                Complete Registration
            </button>
        </form>
    </div>

    <div id="cameraModal" class="camera-modal" aria-hidden="true">
        <div class="camera-panel">
            <video id="cameraVideo" class="camera-live" autoplay playsinline muted></video>
            <div id="camera-status">Camera ready. Capture up to 5 photos.</div>
            <div class="camera-actions">
                <button type="button" id="capturePhotoBtn" class="camera-btn capture">Capture Photo</button>
                <button type="button" id="doneCameraBtn" class="camera-btn done">Done</button>
                <button type="button" id="cancelCameraBtn" class="camera-btn cancel">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        const carPhotosGallery = document.getElementById('car_photos_gallery');
        const carPhotosCamera = document.getElementById('car_photos_camera');
        const addCarForm = document.getElementById('addCarForm');
        const cameraModal = document.getElementById('cameraModal');
        const cameraVideo = document.getElementById('cameraVideo');
        const cameraStatus = document.getElementById('camera-status');
        const capturePhotoBtn = document.getElementById('capturePhotoBtn');
        const doneCameraBtn = document.getElementById('doneCameraBtn');
        const cancelCameraBtn = document.getElementById('cancelCameraBtn');

        let activeCameraStream = null;
        const cameraCapturedFiles = [];

        function getAllSelectedFiles() {
            const galleryFiles = Array.from(carPhotosGallery.files || []);
            const cameraFiles = Array.from(carPhotosCamera.files || []);
            return [...galleryFiles, ...cameraFiles];
        }

        function renderCarPreview(files) {
            const preview = document.getElementById('preview-grid');
            preview.innerHTML = '';
            Array.from(files).forEach(file => {
                const reader = new FileReader();
                reader.onload = (ev) => {
                    const img = document.createElement('img');
                    img.src = ev.target.result;
                    img.className = 'preview-img';
                    preview.appendChild(img);
                }
                reader.readAsDataURL(file);
            });
        }

        function syncCameraInputFiles() {
            const transfer = new DataTransfer();
            cameraCapturedFiles.forEach((file) => transfer.items.add(file));
            carPhotosCamera.files = transfer.files;
        }

        async function openCameraModal() {
            if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                carPhotosCamera.click();
                return;
            }

            try {
                activeCameraStream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: { ideal: 'environment' } },
                    audio: false
                });
                cameraVideo.srcObject = activeCameraStream;
                cameraModal.classList.add('active');
                cameraModal.setAttribute('aria-hidden', 'false');
                cameraStatus.textContent = `Camera ready. Captured ${cameraCapturedFiles.length}/5.`;
            } catch (error) {
                alert('Camera access was blocked. Please allow camera permission, then try again.');
            }
        }

        function closeCameraModal() {
            cameraModal.classList.remove('active');
            cameraModal.setAttribute('aria-hidden', 'true');
            if (activeCameraStream) {
                activeCameraStream.getTracks().forEach((track) => track.stop());
                activeCameraStream = null;
            }
            cameraVideo.srcObject = null;
        }

        function captureFromCamera() {
            if (!cameraVideo.videoWidth || !cameraVideo.videoHeight) return;
            if (cameraCapturedFiles.length >= 5) {
                cameraStatus.textContent = 'Maximum 5 photos reached.';
                return;
            }

            const canvas = document.createElement('canvas');
            canvas.width = cameraVideo.videoWidth;
            canvas.height = cameraVideo.videoHeight;
            const context = canvas.getContext('2d');
            context.drawImage(cameraVideo, 0, 0, canvas.width, canvas.height);

            canvas.toBlob((blob) => {
                if (!blob) return;
                const file = new File([blob], `camera-car-${Date.now()}.jpg`, { type: 'image/jpeg' });
                cameraCapturedFiles.push(file);
                syncCameraInputFiles();
                renderCarPreview(getAllSelectedFiles());
                cameraStatus.textContent = `Captured ${cameraCapturedFiles.length}/5. You can capture more or tap Done.`;
            }, 'image/jpeg', 0.9);
        }

        function triggerCarPhotoSource(source) {
            if (source === 'camera') {
                openCameraModal();
                return;
            }
            carPhotosGallery.click();
        }

        window.triggerCarPhotoSource = triggerCarPhotoSource;

        capturePhotoBtn.addEventListener('click', captureFromCamera);
        doneCameraBtn.addEventListener('click', () => {
            closeCameraModal();
            renderCarPreview(getAllSelectedFiles());
        });
        cancelCameraBtn.addEventListener('click', closeCameraModal);

        carPhotosGallery.onchange = () => {
            renderCarPreview(getAllSelectedFiles());
        };

        // Fallback path for devices that use native capture input.
        carPhotosCamera.onchange = () => {
            renderCarPreview(getAllSelectedFiles());
        };

        addCarForm.addEventListener('submit', (e) => {
            const hasGalleryFiles = carPhotosGallery.files && carPhotosGallery.files.length > 0;
            const hasCameraFiles = carPhotosCamera.files && carPhotosCamera.files.length > 0;
            if (!hasGalleryFiles && !hasCameraFiles) {
                e.preventDefault();
                alert('Please upload or take at least one car photo.');
            }
        });

        window.addEventListener('beforeunload', closeCameraModal);
    </script>
    <!-- Include these at the bottom of your <body> -->
<link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
<%- include('../partials/alerts') %>
</body>
</html>