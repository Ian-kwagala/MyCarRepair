<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register Vehicle | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
    <style>
        .form-container { background: white; border-radius: 30px; margin-top: -30px; padding: 30px 20px; box-shadow: 0 -10px 40px rgba(0,0,0,0.1); }
        .section-title { font-size: 11px; font-weight: 800; color: #94a3b8; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 12px; display: block; }
        .input-box { background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 14px; padding: 12px 15px; margin-bottom: 15px; display: flex; align-items: center; gap: 10px; transition: 0.3s; }
        .input-box:focus-within { border-color: var(--action-orange); background: white; }
        .input-box input, .input-box select { border: none; background: transparent; width: 100%; outline: none; font-size: 15px; font-weight: 600; color: #1e293b; }
        #preview-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 15px; }
        .preview-img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 12px; animation: popScale 0.3s ease-out; }
    </style>
</head>
<body style="background: #0f172a; padding-bottom: 40px;">

    <div style="padding: 50px 20px 60px 20px; text-align: center; color: white;">
        <h2 style="font-size: 28px; font-weight: 900;">Register Vehicle</h2>
        <p style="opacity: 0.6; font-size: 14px;">Essential for emergency & maintenance accuracy</p>
    </div>

    <div class="form-container">
        <form action="/owner/add-car" method="POST" enctype="multipart/form-data">
            
            <span class="section-title">Identity</span>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="input-box"><input type="text" name="make" placeholder="Make (Toyota)" required></div>
                <div class="input-box"><input type="text" name="model" placeholder="Model (Wish)" required></div>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="input-box"><input type="text" name="plate" placeholder="Plate No." required></div>
                <div class="input-box"><input type="number" name="year" placeholder="Year" value="2025" required></div>
            </div>

            <span class="section-title" style="margin-top: 15px;">Technical Specs</span>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="input-box">
                    <select name="fuel_type" required>
                        <option value="" disabled selected>Fuel Type</option>
                        <option value="Petrol">Petrol</option>
                        <option value="Diesel">Diesel</option>
                        <option value="Hybrid">Hybrid</option>
                        <option value="Electric">Electric</option>
                    </select>
                </div>
                <div class="input-box"><input type="text" name="tyre_size" placeholder="Tyre Size (e.g. 195/65R15)"></div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="input-box">
                    <select name="transmission">
                        <option value="Automatic">Automatic</option>
                        <option value="Manual">Manual</option>
                    </select>
                </div>
                <div class="input-box"><input type="text" name="color" placeholder="Color"></div>
            </div>

            <span class="section-title" style="margin-top: 15px;">Status</span>
            <div class="input-box">
                <i data-lucide="gauge" size="18" color="#94a3b8"></i>
                <input type="number" name="mileage" placeholder="Current Mileage (Km)">
            </div>
            <div class="input-box">
                <i data-lucide="calendar" size="18" color="#94a3b8"></i>
                <input type="text" name="last_service" onfocus="(this.type='date')" placeholder="Last Service Date">
            </div>

            <span class="section-title" style="margin-top: 15px;">Visuals</span>
            <label class="photo-upload-zone" style="border: 2px dashed #cbd5e1; padding: 20px; display: block; border-radius: 20px; text-align: center; cursor: pointer;">
                <i data-lucide="camera" size="32" color="#94a3b8"></i>
                <p style="font-size: 12px; color: #94a3b8;">Tap to upload car photos</p>
                <input type="file" name="car_photos" id="car_photos" multiple accept="image/*" style="display: none;">
                <div id="preview-grid"></div>
            </label>

            <button type="submit" class="btn-primary" style="width: 100%; margin-top: 30px; padding: 20px; border-radius: 18px; font-weight: 800;">
                Complete Registration
            </button>
        </form>
    </div>

    <script>
        lucide.createIcons();
        document.getElementById('car_photos').onchange = (e) => {
            const preview = document.getElementById('preview-grid');
            preview.innerHTML = '';
            Array.from(e.target.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = (ev) => {
                    const img = document.createElement('img');
                    img.src = ev.target.result;
                    img.className = 'preview-img';
                    preview.appendChild(img);
                }
                reader.readAsDataURL(file);
            });
        };
    </script>
</body>
</html>