<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Emergency SOS | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/alerts.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/alerts.js"></script>
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <style>
        body {
            background: #b91c1c;
            transition: background 1s ease;
            overflow-x: hidden;
        }

        .sos-header {
            background: linear-gradient(180deg, rgba(0, 0, 0, 0.3) 0%, rgba(185, 28, 28, 0) 100%);
            padding: 52px 24px 34px;
            text-align: center;
            color: white;
        }

        .pulse-icon-container {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.18);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px;
            position: relative;
        }

        .pulse-ring {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 2px solid white;
            animation: sosPulse 2s infinite;
        }

        @keyframes sosPulse {
            0% { transform: scale(1); opacity: 0.8; }
            100% { transform: scale(2); opacity: 0; }
        }

        .sos-content-card {
            background: white;
            border-radius: 34px 34px 0 0;
            min-height: 70vh;
            padding: 26px 18px 34px;
            box-shadow: 0 -15px 40px rgba(0, 0, 0, 0.2);
        }

        .vehicle-selector-card {
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 20px;
            padding: 15px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .issue-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .issue-btn {
            background: white;
            border: 2px solid #f1f5f9;
            border-radius: 22px;
            padding: 22px 14px;
            text-align: center;
            cursor: pointer;
            transition: 0.25s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .issue-btn i {
            color: #94a3b8;
            transition: 0.25s ease;
        }

        .issue-btn span {
            font-weight: 800;
            font-size: 13px;
            color: #1e293b;
        }

        .issue-btn:hover,
        .issue-btn:active {
            transform: translateY(-1px);
            background: #fef2f2;
            border-color: #fca5a5;
        }

        .issue-btn:hover i,
        .issue-btn:active i {
            color: #ef4444;
        }

        .radar-container {
            padding: 38px 0;
            text-align: center;
        }

        .radar {
            width: 120px;
            height: 120px;
            border: 4px solid #ef4444;
            border-radius: 50%;
            margin: 0 auto 30px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .radar-sweep {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 4px solid #ef4444;
            animation: radarScan 2s linear infinite;
        }

        @keyframes radarScan {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(2.5); opacity: 0; }
        }

        .mechanic-arriving-card {
            background: white;
            border-radius: 25px;
            padding: 24px;
            margin-top: 18px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .animate-spring {
            animation: spring 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @keyframes spring {
            0% { transform: scale(0.8) translateY(20px); opacity: 0; }
            100% { transform: scale(1) translateY(0); opacity: 1; }
        }

        .mech-avatar-large {
            width: 60px;
            height: 60px;
            border-radius: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 8px 16px rgba(102, 126, 234, 0.4);
            flex: 0 0 auto;
        }

        .rating-pill {
            background: #fef3c7;
            color: #f59e0b;
            padding: 4px 8px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            gap: 3px;
        }

        .btn-call {
            background: #22c55e;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 16px;
            border-radius: 15px;
            text-decoration: none;
            font-weight: 800;
            font-size: 16px;
            box-shadow: 0 10px 20px rgba(34, 197, 94, 0.3);
        }

        .btn-cancel {
            background: none;
            border: 1px solid #cbd5e1;
            padding: 10px 20px;
            border-radius: 10px;
            color: #64748b;
            margin-top: 34px;
        }

        @media (max-width: 640px) {
            .issue-grid {
                grid-template-columns: 1fr;
            }

            .sos-header {
                padding-inline: 18px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/back-nav') %>

    <%
        const carsValue = Array.isArray(cars) ? cars : [];
        const userNameValue = typeof userName === 'string' && userName.trim() ? userName : 'Driver';
        const userIdValue = userId || '';
        const defaultVehicleId = carsValue.length > 0 ? carsValue[0].id : '';
        const etaValue = typeof estimatedETA === 'string' ? estimatedETA : '8 - 12 minutes';
        const mechCountValue = typeof mechanicCount === 'number' ? mechanicCount : 0;
    %>

    <div class="sos-header">
        <div class="pulse-icon-container">
            <div class="pulse-ring"></div>
            <i data-lucide="alert-octagon" size="40" color="white"></i>
        </div>
        <h1 style="font-weight: 900; letter-spacing: -1px; font-size: 32px; margin: 0;">Emergency SOS</h1>
        <p style="opacity: 0.82; font-size: 14px; margin-top: 6px;">Help is just one tap away</p>
    </div>

    <div class="sos-content-card">
        <div id="selection-screen">
            <span class="label-mini" style="color: #94a3b8; font-weight: 800; margin-bottom: 10px; display: block;">STEP 1: SELECT VEHICLE</span>
            <div class="vehicle-selector-card">
                <div style="background: var(--action-orange); padding: 10px; border-radius: 12px; color: white;">
                    <i data-lucide="car"></i>
                </div>
                <select id="sos-vehicle-id" style="flex: 1; border: none; background: transparent; font-weight: 800; font-size: 16px; outline: none; color: #1e293b;">
                    <% if (carsValue.length === 0) { %>
                        <option value="">No vehicles available</option>
                    <% } else { %>
                        <% carsValue.forEach(car => { %>
                            <option value="<%= car.id %>"><%= car.make %> <%= car.model %> (<%= car.plate_number %>)</option>
                        <% }) %>
                    <% } %>
                </select>
            </div>

            <span class="label-mini" style="color: #94a3b8; font-weight: 800; margin-bottom: 15px; display: block;">STEP 2: WHAT IS THE ISSUE?</span>
            <div class="issue-grid">
                <div class="issue-btn" onclick="triggerSOS('Flat Tire')"><i data-lucide="disc"></i><span>Flat Tire</span></div>
                <div class="issue-btn" onclick="triggerSOS('Dead Battery')"><i data-lucide="battery-warning"></i><span>Dead Battery</span></div>
                <div class="issue-btn" onclick="triggerSOS('Engine Failure')"><i data-lucide="engine"></i><span>Engine Failure</span></div>
                <div class="issue-btn" onclick="triggerSOS('Towing')"><i data-lucide="truck"></i><span>Towing</span></div>
                <div class="issue-btn" onclick="triggerSOS('Low Fuel')"><i data-lucide="fuel"></i><span>Low Fuel</span></div>
                <div class="issue-btn" onclick="triggerSOS('Car Crash')"><i data-lucide="alert-triangle"></i><span>Car Crash</span></div>
            </div>
        </div>

        <div id="searching-screen" style="display: none;" class="radar-container">
            <div class="radar">
                <div class="radar-sweep"></div>
                <div class="radar-sweep" style="animation-delay: 1s;"></div>
                <i data-lucide="map-pin" size="32" color="#ef4444"></i>
            </div>
            <h2 style="color: #1e293b; font-weight: 900; margin: 0;">Broadcasting...</h2>
            <p id="sos-status" style="color: #64748b; margin: 15px 0;">Pinpointing your exact coordinates</p>
            
            <div style="background: #fef2f2; border: 2px solid #fca5a5; border-radius: 18px; padding: 18px; margin: 24px 0; text-align: left;">
                <div style="display: flex; gap: 20px; margin-bottom: 12px;">
                    <div style="flex: 1;">
                        <p style="margin: 0; font-size: 11px; font-weight: 800; color: #991b1b; text-transform: uppercase;">Available Mechanics</p>
                        <p style="margin: 8px 0 0; font-size: 20px; font-weight: 900; color: #b91c1c;" id="mech-count-display"><%= mechCountValue %></p>
                    </div>
                    <div style="flex: 1;">
                        <p style="margin: 0; font-size: 11px; font-weight: 800; color: #991b1b; text-transform: uppercase;">Estimated Arrival</p>
                        <p style="margin: 8px 0 0; font-size: 18px; font-weight: 900; color: #b91c1c;" id="eta-display"><%= etaValue %></p>
                    </div>
                </div>
                <p style="margin: 0; font-size: 12px; color: #991b1b; font-weight: 600;"><i data-lucide="info" size="14" style="vertical-align: middle; margin-right: 6px;"></i>Alerts sent to nearby mechanics</p>
            </div>
            
            <button onclick="cancelSOS()" class="btn-cancel">Cancel Request</button>
        </div>

        <div id="accepted-screen" style="display: none;">
            <div class="mechanic-arriving-card animate-spring">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
                    <div class="mech-avatar-large">
                        <i data-lucide="user" size="32"></i>
                    </div>
                    <div>
                        <h3 id="mech-name" style="margin: 0; color: #0f172a;">--</h3>
                        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 5px; align-items: center;">
                            <span class="rating-pill"><i data-lucide="star" size="10" fill="currentColor"></i> <span id="mech-rating">4.9</span></span>
                            <span style="font-size: 11px; color: #64748b; font-weight: 700;" id="mech-jobs">Verified Mechanic</span>
                        </div>
                    </div>
                </div>

                <div style="background: #f8fafc; padding: 15px; border-radius: 15px; margin-bottom: 18px; border: 1px solid #e2e8f0;">
                    <p style="font-size: 11px; font-weight: 800; color: #94a3b8; margin-bottom: 5px;">ESTIMATED ARRIVAL</p>
                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                        <strong id="arrival-time" style="color: #15803d; font-size: 16px;"><i data-lucide="navigation" size="14"></i> 8 - 12 Minutes</strong>
                    </div>
                    <p id="distance-info" style="font-size: 11px; color: #64748b; margin: 0; font-weight: 600;"></p>
                </div>

                <a href="#" id="mech-call-link" class="btn-call">
                    <i data-lucide="phone"></i> Call Mechanic
                </a>
                
                <a href="#" id="mech-map-link" style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 12px; padding: 16px; background: #dbeafe; color: #0369a1; text-decoration: none; border-radius: 15px; font-weight: 800; font-size: 14px;">
                    <i data-lucide="map"></i> View on Map
                </a>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        const socket = io();
        const ownerName = <%- JSON.stringify(userNameValue) %>;
        const fallbackVehicleId = <%- JSON.stringify(defaultVehicleId) %>;
        const ownerId = <%- JSON.stringify(userIdValue) %>;

        let myJobId = null;
        let myOwnerLat = null;
        let myOwnerLng = null;

        async function updateOwnerLocation(lat, lng) {
            myOwnerLat = lat;
            myOwnerLng = lng;
            try {
                await fetch('/api/owner/update-location', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lat, lng })
                });
            } catch (err) {
                console.error('Failed to sync SOS location:', err);
            }
        }

        function cancelSOS() {
            const btn = event.target;
            btn.disabled = true;
            btn.innerText = 'Cancelling...';
            socket.emit('cancel_sos');
        }

        function triggerSOS(issue) {
            const vehicleSelect = document.getElementById('sos-vehicle-id');
            const vehicleId = vehicleSelect && vehicleSelect.value ? vehicleSelect.value : fallbackVehicleId;

            if (!vehicleId) {
                AppAlert.show('Car Required', 'Please add or select a vehicle before sending SOS.', 'warning');
                return;
            }

            const selectionScreen = document.getElementById('selection-screen');
            const searchingScreen = document.getElementById('searching-screen');
            const statusMsg = document.getElementById('sos-status');

            if (selectionScreen) selectionScreen.style.display = 'none';
            if (searchingScreen) searchingScreen.style.display = 'block';
            if (statusMsg) statusMsg.innerText = 'Pinpointing your exact location...';

            if (!navigator.geolocation) {
                AppAlert.show('Not Supported', 'Your browser does not support location tracking.', 'error');
                location.reload();
                return;
            }

            navigator.geolocation.getCurrentPosition(
                (position) => {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;

                    updateOwnerLocation(lat, lng);

                    socket.emit('emergency_sos', {
                        issue,
                        ownerName,
                        vehicleId,
                        lat,
                        lng,
                        ownerId
                    });

                    if (statusMsg) statusMsg.innerText = 'Alerting nearby mechanics...';
                },
                () => {
                    AppAlert.show('GPS Error', 'Location access denied. We need your location to send help.', 'error');
                    location.reload();
                },
                { enableHighAccuracy: true }
            );
        }

        socket.on('sos_confirmed', (data) => {
            myJobId = data.jobId;
        });

        socket.on('sos_cancelled_confirmed', (data) => {
            if (data.success) {
                AppAlert.show('Cancelled', 'Your emergency request has been cancelled.', 'success');
                setTimeout(() => {
                    location.href = '/owner/dashboard';
                }, 1500);
            }
        });

        socket.on('job_taken', (data) => {
            if (data.jobId != myJobId) return;

            document.body.style.background = '#15803d';
            const searchingScreen = document.getElementById('searching-screen');
            const acceptedScreen = document.getElementById('accepted-screen');

            if (searchingScreen) searchingScreen.style.display = 'none';
            if (acceptedScreen) acceptedScreen.style.display = 'block';

            const mechName = document.getElementById('mech-name');
            const mechRating = document.getElementById('mech-rating');
            const mechJobs = document.getElementById('mech-jobs');
            const mechCall = document.getElementById('mech-call-link');
            const arrivalTime = document.getElementById('arrival-time');
            const distanceInfo = document.getElementById('distance-info');
            const mechMapLink = document.getElementById('mech-map-link');

            if (mechName) mechName.innerText = data.mechanicName || '--';
            if (mechRating) mechRating.innerText = data.mechanicRating ? Number(data.mechanicRating).toFixed(1) : '4.9';
            if (mechJobs) mechJobs.innerText = 'Verified Mechanic';
            if (mechCall) mechCall.href = data.mechanicPhone ? `tel:${data.mechanicPhone}` : '#';
            
            // Display estimated arrival time
            if (arrivalTime && data.estimatedArrival) {
                arrivalTime.innerHTML = '<i data-lucide="navigation" size="14"></i> ' + data.estimatedArrival;
            }
            
            // Display distance information
            if (distanceInfo && data.distance) {
                distanceInfo.innerHTML = `<i data-lucide="map-pin" size="12"></i> ${data.distance} km away`;
            }
            
            // Generate Google Maps link
            if (mechMapLink && data.mechanicLat && data.mechanicLng && myOwnerLat && myOwnerLng) {
                const mapsUrl = `https://www.google.com/maps/dir/${myOwnerLat},${myOwnerLng}/${data.mechanicLat},${data.mechanicLng}`;
                mechMapLink.href = mapsUrl;
                mechMapLink.target = '_blank';
            }

            lucide.createIcons();
        });
    </script>

    <%- include('../partials/alerts') %>
</body>
</html>
