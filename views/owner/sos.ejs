<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Emergency SOS | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/socket.io/socket.io.js"></script> <!-- Load Socket.io -->
    <link rel="stylesheet" href="/css/alert.css">
    <script src="/js/alert.js"></script>
</head>
<body style="background: var(--emergency-red); color: white;">

    <div style="padding: 40px 20px; text-align: center;">
        <i data-lucide="alert-octagon" size="60" style="margin-bottom: 20px;"></i>
        <h1>Emergency SOS</h1>
        <p>Stay calm. We are finding the nearest mechanics.</p>
    </div>

    <div style="background: white; border-radius: 30px 30px 0 0; padding: 30px 20px; min-height: 60vh;">
        <div id="sos-ui">
            <!-- Initial Issue Selection -->
            <div id="selection-screen">
                <h3 style="color: #1e293b; margin-bottom: 20px;">What is the issue?</h3>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <button class="sos-type" onclick="sendSOS('Engine Failure')">Engine Failure</button>
                    <button class="sos-type" onclick="sendSOS('Flat Tire')"><i data-lucide="disc"></i> Flat Tire</button>
                    <button class="sos-type" onclick="sendSOS('Dead Battery')"><i data-lucide="battery-warning"></i> Dead Battery</button>
                    <button class="sos-type" onclick="sendSOS('Towing')"><i data-lucide="truck"></i> Towing</button>
                    <button class="sos-type" onclick="sendSOS('Low Fuel')"><i data-lucide="fuel"></i> Low Fuel</button>
                    <button class="sos-type" onclick="sendSOS('Car Crash')"><i data-lucide="alert-triangle"></i> Car Crash</button>
                </div>
            </div>

            <!-- Waiting Screen (Hidden by default) -->
            <div id="waiting-screen" style="display: none; text-align: center; padding: 40px 0;">
                <div class="pulse-loader"></div>
                <h2 style="color: #1e293b;">Finding Mechanic...</h2>
                <p id="comfort-msg" style="color: #64748b; margin: 15px 0;">Connecting you to the nearest expert.</p>
                <button onclick="cancelSOS()" style="background: none; border: 1px solid #cbd5e1; padding: 10px 20px; border-radius: 8px; color: #64748b; margin-top: 40px;">Cancel Request</button>
            </div>

            <!-- Accepted UI (Hidden by default) -->
            <div id="accepted-ui" style="display: none;">
                <div class="mechanic-arriving-card animate-spring">
                    <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
                        <div class="mech-avatar-large">
                            <i data-lucide="user" size="32"></i>
                        </div>
                        <div>
                            <h3 id="mech-name" style="margin: 0; color: #0f172a;">--</h3>
                            <div style="display: flex; gap: 10px; margin-top: 5px;">
                                <span class="rating-pill"><i data-lucide="star" size="10" fill="currentColor"></i> <span id="mech-rating">4.9</span></span>
                                <span style="font-size: 11px; color: #64748b; font-weight: 700;" id="mech-jobs">0 Jobs Done</span>
                            </div>
                        </div>
                    </div>

                    <div style="background: #f8fafc; padding: 15px; border-radius: 15px; margin-bottom: 20px; border: 1px solid #e2e8f0;">
                        <p style="font-size: 11px; font-weight: 800; color: #94a3b8; margin-bottom: 5px;">ESTIMATED ARRIVAL</p>
                        <strong style="color: #15803d;"><i data-lucide="navigation" size="14"></i> 8 - 12 Minutes</strong>
                    </div>

                    <a href="#" id="mech-call-link" class="btn-call">
                        <i data-lucide="phone"></i> Call Mechanic
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- <label class="label-text">VEHICLE INVOLVED</label>
    <div class="input-box">
        <i data-lucide="car" size="18" color="#94a3b8"></i>
        <select name="vehicle_id" required style="width: 100%; border: none; background: transparent; font-weight: 700;">
            <% if (cars.length === 0) { %>
                <option disabled selected>Please add a car in your garage first</option>
            <% } else { %>
                <!-- If only 1 car, this option becomes 'selected' automatically -->
                <% cars.forEach(car => { %>
                    <option value="<%= car.id %>" <%= cars.length === 1 ? 'selected' : '' %>>
                        <%= car.make %> <%= car.model %> (<%= car.plate_number %>)
                    </option>
                <% }); %>
            <% } %>
        </select>
    </div>

    <!-- Add this ABOVE the 'What is the issue?' buttons
    <div style="background: white; border-radius: 20px; padding: 20px; margin-bottom: 25px; border: 1.5px solid #e2e8f0;" class="reveal">
        <span class="label-text" style="color: #64748b; font-size: 11px;">EMERGENCY VEHICLE</span>
        <div style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
            <select id="sos-vehicle-id" style="width: 100%; padding: 10px; border-radius: 10px; border: 1px solid #f1f5f9; font-weight: 700; color: var(--primary-blue);">
                <% cars.forEach(car => { %>
                    <option value="<%= car.id %>" <%= cars.length === 1 ? 'selected' : '' %>><%= car.make %> <%= car.model %> (<%= car.plate_number %>)</option>
                <% }); %>
            </select>
        </div>
    </div>

    <!-- Professional Emergency Vehicle Selection Card -->
    <div class="sos-car-card animate-pop-in">
        <div style="display: flex; align-items: center; gap: 10px;">
            <i data-lucide="car" size="22" color="#0f172a"></i>
            <span class="label-text" style="font-size: 13px; font-weight: 800; color: #0f172a;">Select Emergency Vehicle</span>
        </div>
        <div style="margin-top: 12px;">
            <select id="sos-vehicle-id" class="sos-select" required>
                <% if (cars.length === 0) { %>
                    <option disabled selected>Please add a car in your garage first</option>
                <% } else { %>
                    <% cars.forEach(car => { %>
                        <option value="<%= car.id %>" <%= cars.length === 1 ? 'selected' : '' %>>
                            <%= car.make %> <%= car.model %> (<%= car.plate_number %>)
                        </option>
                    <% }); %>
                <% } %>
            </select>
        </div>
    </div> 

    <style>
        /* THE TRANSITION TO HELP */
        body.help-arriving {
            background: #15803d !important; /* Professional Forest Green */
            transition: background 1s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .mechanic-arriving-card {
            background: white; border-radius: 25px; padding: 25px;
            margin-top: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .animate-spring {
            animation: spring 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @keyframes spring {
            0% { transform: scale(0.8) translateY(20px); opacity: 0; }
            100% { transform: scale(1) translateY(0); opacity: 1; }
        }

        .mech-avatar-large {
            width: 60px; height: 60px; border-radius: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex; align-items: center; justify-content: center;
            color: white; box-shadow: 0 8px 16px rgba(102, 126, 234, 0.4);
        }

        .rating-pill {
            background: #fef3c7; color: #f59e0b; padding: 4px 8px;
            border-radius: 8px; font-size: 11px; font-weight: 800;
            display: inline-flex; align-items: center; gap: 3px;
        }

        .btn-call {
            background: #22c55e; color: white; display: flex; align-items: center;
            justify-content: center; gap: 10px; padding: 18px; border-radius: 15px;
            text-decoration: none; font-weight: 800; font-size: 18px;
            box-shadow: 0 10px 20px rgba(34, 197, 94, 0.3);
        }
    </style>

    <script>
        lucide.createIcons();
        const socket = io();
        const messages = ["Mechanics usually arrive in 10-15 mins.", "We've notified 5 nearby garages.", "Stay safe, help is on the way."];
        let msgIndex = 0;
        let myJobId = null; // Store the job ID returned from server

        function sendSOS(issue) {
            const selectedVehicle = document.getElementById('sos-vehicle-id').value;
            
            if(!selectedVehicle) {
                alert("Please register or select a car first!");
                return;
            }

            document.getElementById('selection-screen').style.display = 'none';
            document.getElementById('waiting-screen').style.display = 'block';
            
            // Now sending vehicle_id so server can fetch fuel/tyre details
            socket.emit('emergency_sos', { 
                issue: issue, 
                ownerName: "<%= userName %>",
                vehicleId: selectedVehicle 
            });
            
            // Cycle comforting messages
            setInterval(() => {
                document.getElementById('comfort-msg').innerText = messages[msgIndex % messages.length];
                msgIndex++;
            }, 4000);
        }

        // Listen for SOS confirmation with availability info
        socket.on('sos_confirmed', (data) => {
            myJobId = data.jobId;
            console.log(`SOS Job Created: ${myJobId} | ${data.availableMechanics} mechanic(s) online`);
            
            // Warn owner if no mechanics are available
            if (data.noMechanicsWarning) {
                document.getElementById('comfort-msg').innerText = "⚠️ No mechanics online right now. We'll notify them when they come online.";
                document.getElementById('comfort-msg').style.color = "#f59e0b"; // Warning yellow
            }
        });

        function cancelSOS() {
            socket.emit('cancel_sos');
            location.href = '/owner/dashboard';
        }
        
        socket.on('job_taken', (data) => {
            // 1. Check if the accepted job is MINE
            if (data.jobId == myJobId) {
                
                // 2. Change background to Green
                document.body.classList.add('help-arriving');

                // 3. Hide waiting screen
                document.getElementById('waiting-screen').style.display = 'none';

                // 4. Show Enhanced Mechanic Profile
                document.getElementById('mech-name').innerText = data.mechanicName;
                document.getElementById('mech-jobs').innerText = data.jobsDone + " Jobs Done";
                if (data.mechanicRating) {
                    document.getElementById('mech-rating').innerText = data.mechanicRating;
                }
                document.getElementById('mech-call-link').href = "tel:" + data.mechanicPhone;
                document.getElementById('accepted-ui').style.display = 'block';
                
                // Play success sound
                new Audio('https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3').play();
                
                lucide.createIcons();
            }
        });
    </script>


</body>
</html>