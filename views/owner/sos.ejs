    <style>
        /* THE TRANSITION TO HELP */
        body.help-arriving {
            background: #15803d !important; /* Professional Forest Green */
            transition: background 1s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .mechanic-arriving-card {
            background: white; border-radius: 25px; padding: 25px;
            margin-top: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .animate-spring {
            animation: spring 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @keyframes spring {
            0% { transform: scale(0.8) translateY(20px); opacity: 0; }
            100% { transform: scale(1) translateY(0); opacity: 1; }
        }

        .mech-avatar-large {
            width: 60px; height: 60px; border-radius: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex; align-items: center; justify-content: center;
            color: white; box-shadow: 0 8px 16px rgba(102, 126, 234, 0.4);
        }

        .rating-pill {
            background: #fef3c7; color: #f59e0b; padding: 4px 8px;
            border-radius: 8px; font-size: 11px; font-weight: 800;
            display: inline-flex; align-items: center; gap: 3px;
        }

        .btn-call {
            background: #22c55e; color: white; display: flex; align-items: center;
            justify-content: center; gap: 10px; padding: 18px; border-radius: 15px;
            text-decoration: none; font-weight: 800; font-size: 18px;
            box-shadow: 0 10px 20px rgba(34, 197, 94, 0.3);
        }
    </style>

    <script>
        lucide.createIcons();
        const messages = ["Mechanics usually arrive in 10-15 mins.", "We've notified 5 nearby garages.", "Stay safe, help is on the way."];
        let msgIndex = 0;
        let myJobId = null; // Store the job ID returned from server

        async function updateOwnerLocation(lat, lng) {
            try {
                await fetch('/api/owner/update-location', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lat, lng })
                });
            } catch (err) {
                console.error('Failed to sync SOS location:', err);
            }
        }

        // --- UPDATED SOS TRIGGER LOGIC ---
        function sendSOS(issue) {
            const vehicleSelect = document.getElementById('sos-vehicle-id');
            const selectedVehicle = vehicleSelect ? vehicleSelect.value : '<%= (cars && cars.length > 0) ? cars[0].id : "" %>';
            const statusMsg = document.getElementById('comfort-msg');

            if(!selectedVehicle) {
                AppAlert.show("Car Required", "Please select which car needs help.", "warning");
                return;
            }

            // 1. PROMPT FOR EXACT LOCATION
            statusMsg.innerText = "🛰️ Pinpointing your exact location...";
            
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        const lat = position.coords.latitude;
                        const lng = position.coords.longitude;

                        updateOwnerLocation(lat, lng);

                        // 2. SWITCH TO WAITING UI
                        document.getElementById('selection-screen').style.display = 'none';
                        document.getElementById('waiting-screen').style.display = 'block';

                        // 3. SEND SOS WITH GPS TO SERVER
                        socket.emit('emergency_sos', { 
                            issue: issue, 
                            ownerName: "<%= userName %>",
                            vehicleId: selectedVehicle,
                            lat: lat,
                            lng: lng
                        });
                    },
                    (error) => {
                        AppAlert.show("GPS Error", "We need your location to send a mechanic. Please enable GPS.", "error");
                    },
                    { enableHighAccuracy: true } // Forces the phone to use GPS, not just WiFi
                );
            } else {
                AppAlert.show("Not Supported", "Your browser does not support location tracking.", "error");
            }
        }

        // --- FIX: STATE TRANSITION FOR SOS CONFIRMATION ---
        socket.on('sos_confirmed', (data) => {
            window.myJobId = data.jobId; // Set global ID so we know which job is ours
            console.log("SOS Saved in DB. Tracking ID:", window.myJobId);
        });

        function cancelSOS() {
            socket.emit('cancel_sos');
            location.href = '/owner/dashboard';
        }
        
        function showAcceptedMechanicUI(data) {
            // CRITICAL CHECK: Does the incoming 'Accept' signal match my active SOS ID?
            if (data.jobId != window.myJobId) return;

            console.log('Mechanic accepted my job!');

            // 1. Transform UI to Green
            document.body.classList.add('help-arriving');

            // 2. Hide waiting spinner, update title, hide comfort text
            document.getElementById('status-indicator').style.display = 'none';
            document.getElementById('wait-title').innerText = 'Mechanic is Coming!';
            document.getElementById('comfort-msg').style.display = 'none';

            // 3. Populate Mechanic Data
            document.getElementById('mech-name').innerText = data.mechanicName || '--';
            document.getElementById('mech-rating').innerText = data.mechanicRating ? Number(data.mechanicRating).toFixed(1) : '4.9';
            document.getElementById('mech-jobs').innerText = data.jobsDone ? (data.jobsDone + ' Jobs Done') : 'Verified Mechanic';
            document.getElementById('mech-call-link').href = data.mechanicPhone ? ('tel:' + data.mechanicPhone) : '#';
            document.getElementById('accepted-ui').style.display = 'block';

            lucide.createIcons();
        }

        socket.on('job_taken', (data) => {
            showAcceptedMechanicUI(data);
        });

        /*
        socket.on('job_accepted_with_code', (data) => {
            if (data.jobId == window.myJobId) {
                document.body.classList.add('help-arriving');
                // Update Mechanic Info
                document.getElementById('mech-name').innerText = data.mechanicName;
                document.getElementById('mech-call-link').href = 'tel:' + data.mechanicPhone;

                // SHOW THE REAL CODE
                document.getElementById('display-start-code').innerText = data.startCode; // 4-digit code

                document.getElementById('accepted-ui').style.display = 'block';
                lucide.createIcons();
            }
        });
        */
    </script>
