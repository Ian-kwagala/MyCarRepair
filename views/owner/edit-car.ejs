<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Vehicle | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
    <style>
        body {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            font-family: 'Segoe UI', Arial, sans-serif;
            min-height: 100vh;
        }
        .edit-container {
            max-width: 420px;
            margin: 60px auto 0 auto;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 12px 36px rgba(30,41,59,0.18);
            padding: 0;
            overflow: hidden;
            animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(50px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        .edit-header {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #fff;
            padding: 38px 28px 22px 28px;
            border-radius: 24px 24px 0 0;
            text-align: center;
            box-shadow: 0 4px 18px rgba(30,41,59,0.10);
            animation: headerPop 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }
        @keyframes headerPop {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }
        .edit-header h2 {
            margin: 0 0 10px 0;
            font-size: 2.2rem;
            font-weight: 900;
            letter-spacing: -1px;
            text-shadow: 0 2px 8px rgba(30,41,59,0.10);
        }
        .edit-header p {
            margin: 0;
            font-size: 1.08rem;
            opacity: 0.8;
            font-weight: 500;
        }
        .edit-form {
            padding: 32px 28px 28px 28px;
            animation: fadeInUp 1.1s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .section-label {
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 12px;
            font-size: 1.08rem;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }
        .input-row {
            display: flex;
            gap: 12px;
        }
        .input-elegant {
            width: 100%;
            padding: 15px;
            border-radius: 12px;
            border: 1.5px solid #e2e8f0;
            background: #f8fafc;
            font-size: 16px;
            margin-bottom: 16px;
            transition: border-color 0.3s, box-shadow 0.3s;
            font-weight: 500;
        }
        .input-elegant:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.13);
        }
        .update-btn {
            width: 100%;
            padding: 20px;
            border-radius: 16px;
            background: linear-gradient(90deg, #f97316 0%, #fb923c 100%);
            color: #fff;
            font-size: 1.15rem;
            font-weight: 900;
            border: none;
            box-shadow: 0 8px 24px rgba(249,115,22,0.14);
            cursor: pointer;
            transition: background 0.3s, transform 0.2s;
            margin-top: 12px;
            letter-spacing: 0.5px;
        }
        .update-btn:hover {
            background: linear-gradient(90deg, #fb923c 0%, #f97316 100%);
            transform: translateY(-2px) scale(1.04);
        }
    </style>
</head>
<body>
    <div class="edit-container">
        <div class="edit-header">
            <h2>Edit Vehicle</h2>
            <p>Update information for <%= car.make %></p>
        </div>
        <form class="edit-form" action="" method="POST">
            <div class="section-label">Basic Info</div>
            <div class="input-row">
                <input type="text" name="make" class="input-elegant" value="<%= car.make %>" placeholder="Make" required>
                <input type="text" name="model" class="input-elegant" value="<%= car.model %>" placeholder="Model" required>
            </div>
            <div class="section-label">Plate & Mileage</div>
            <input type="text" name="plate" class="input-elegant" value="<%= car.plate_number %>" placeholder="Plate Number" required>
            <input type="number" name="mileage" class="input-elegant" value="<%= car.mileage %>" placeholder="Mileage" min="0">
            <button type="submit" class="update-btn">Update Vehicle</button>
        </form>
    </div>
</body>
</html>