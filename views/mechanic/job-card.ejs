<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Card | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/socket.io/socket.io.js"></script>
    <link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
    <style>
        /* PROFESSIONAL CHECKLIST STYLES */
        .progress-banner {
            background: #f1f5f9; padding: 15px 20px; border-radius: 12px;
            display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;
        }
        .fraction { color: var(--action-orange); font-weight: 800; font-size: 18px; }
        
        .section-label {
            font-size: 11px; font-weight: 800; color: #94a3b8;
            letter-spacing: 1.5px; text-transform: uppercase; margin: 20px 0 10px 0;
        }

        .check-row {
            background: white; border: 1.5px solid #e2e8f0; border-radius: 16px;
            padding: 16px; margin-bottom: 10px; display: flex; align-items: center; gap: 15px;
            transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); cursor: pointer;
        }
        .check-circle {
            width: 24px; height: 24px; border: 2.5px solid #cbd5e1; border-radius: 50%;
            display: flex; align-items: center; justify-content: center; color: transparent;
            transition: 0.3s;
        }
        
        /* State: Completed */
        .check-row.done { border-color: #22c55e; background: #f0fdf4; transform: scale(0.98); }
        .check-row.done .check-circle { background: #22c55e; border-color: #22c55e; color: white; }
        .check-row.done span { color: #15803d; font-weight: 600; text-decoration: line-through; opacity: 0.7; }

        .sticky-actions {
            position: fixed; bottom: 0; left: 0; right: 0; background: white;
            padding: 20px; border-top: 1px solid #e2e8f0; display: flex; gap: 10px;
            box-shadow: 0 -10px 20px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body style="background: #f8fafc; padding-bottom: 120px;">

    <!-- Job Header -->
    <div style="background: #0f172a; color: white; padding: 30px 20px;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h2 style="font-weight: 800; margin: 0;">Digital Job Card</h2>
            <button onclick="location.href='/mechanic/dashboard'" style="background: rgba(255,255,255,0.1); border:none; color:white; padding: 8px; border-radius: 10px;"><i data-lucide="x"></i></button>
        </div>
        <p style="opacity: 0.7; font-size: 13px; margin-top: 5px;"><%= job.owner_name %> • <%= job.make %> <%= job.model %></p>
    </div>

    <div style="padding: 20px;">
        <!-- REAL-TIME PROGRESS BAR -->
        <div class="progress-banner">
            <span style="font-weight: 700; color: #1e293b;">Overall Progress</span>
            <span class="fraction"><span id="completed-count">0</span>/<span id="total-count">10</span></span>
        </div>
        <div style="height: 6px; background: #e2e8f0; border-radius: 10px; margin-top: -33px; margin-bottom: 30px; margin-left: 20px; margin-right: 20px;">
            <div id="bar-fill" style="width: 0%; height: 100%; background: var(--action-orange); border-radius: 10px; transition: 0.5s;"></div>
        </div>

        <!-- DYNAMIC CHECKLIST ITEMS -->
        <p class="section-label">Maintenance Checklist</p>
        <div id="checklist-items">
            <!-- Loaded via JavaScript -->
        </div>

        <!-- PARTS STATUS SECTION -->
        <h4 class="section-label">PART APPROVAL STATUS</h4>
        <div style="background: white; border-radius: 15px; border: 1px solid #e2e8f0; overflow: hidden; margin-bottom: 25px;">
            <% if (parts.length === 0) { %>
                <p style="padding: 15px; font-size: 13px; color: #94a3b8;">No parts quoted yet.</p>
            <% } %>

            <% parts.forEach(part => { %>
                <div style="padding: 15px; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <strong><%= part.part_name %></strong>
                        <p style="font-size: 12px; color: #94a3b8;">UGX <%= part.price.toLocaleString() %></p>
                    </div>

                    <!-- THIS BOX TELLS THE MECHANIC THE STATUS -->
                    <% if (part.is_approved) { %>
                        <div style="background: #dcfce7; color: #15803d; padding: 6px 12px; border-radius: 20px; font-size: 11px; font-weight: 800; display: flex; align-items: center; gap: 5px;">
                            <i data-lucide="check-circle" size="14"></i> APPROVED
                        </div>
                    <% } else { %>
                        <div style="background: #fef3c7; color: #b45309; padding: 6px 12px; border-radius: 20px; font-size: 11px; font-weight: 800; display: flex; align-items: center; gap: 5px;">
                            <i data-lucide="clock" size="14"></i> PENDING
                        </div>
                    <% } %>
                </div>
            <% }) %>
        </div>

        <!-- JOB SUMMARY FOR COMPLETED JOBS -->
        <% if (job.status === 'completed') { %>
            <div style="padding: 20px; background: #f8fafc; border-top: 2px solid #e2e8f0; margin-top: 30px;">
                <h4 class="section-label">JOB SUMMARY (FINISHED)</h4>
                <div style="background: white; padding: 20px; border-radius: 15px; border: 1px solid #e2e8f0;">
                    <p>Your Earnings: <strong>UGX <%= (job.total_price * 0.8).toLocaleString() %></strong> (After 20% Fee)</p>
                    <p style="font-size: 12px; color: #64748b;">The customer has received their digital receipt.</p>
                </div>
            </div>
        <% } %>
    </div>

    <!-- BOTTOM ACTIONS -->
    <div class="sticky-actions">
        <!-- 1. Ability to quote multiple parts -->
        <button onclick="location.href='/mechanic/job/<%= job.id %>/quote'" class="btn-outline" style="flex: 1; border-color: #cbd5e1;">
            <i data-lucide="plus-circle"></i> Quote Part
        </button>
        
        <!-- 2. Final closure -->
        <form action="/mechanic/job/<%= job.id %>/complete" method="POST" style="flex: 2;">
            <button type="submit" class="btn-primary" style="width: 100%; border-radius: 14px;">
                Finish & Generate Receipt
            </button>
        </form>
    </div>

    <script>
        lucide.createIcons();
        const socket = io();
        let total = 0;
        let completed = 0;

        // Real-time update: If owner approves while mechanic is looking at the screen
        socket.on('part_approved_live', (data) => {
            if (data.jobId == '<%= job.id %>') {
                // Use the professional alert we just fixed
                AppAlert.show("Good News!", "The owner has approved the part purchase.", "success", () => {
                    location.reload(); 
                });
            }
        });

        async function loadChecklist() {
            try {
                const res = await fetch('/api/mechanic/job-checklist/<%= job.id %>');
                const tasks = await res.json();
                const container = document.getElementById('checklist-items');
                
                total = tasks.length;
                completed = tasks.filter(t => t.is_completed).length;

                // Update progress display
                document.getElementById('total-count').innerText = total;
                document.getElementById('completed-count').innerText = completed;
                document.getElementById('bar-fill').style.width = (completed / total * 100) + '%';
                
                container.innerHTML = tasks.map(task => `
                    <div class="check-row ${task.is_completed ? 'done' : ''}" onclick="toggleTask(this, ${task.id})">
                        <div class="check-circle"><i data-lucide="check" size="14"></i></div>
                        <span>${task.task_description}</span>
                    </div>
                `).join('');
                lucide.createIcons();
            } catch (err) {
                console.error('Failed to load checklist:', err);
            }
        }

        async function toggleTask(element, taskId) {
            const isNowDone = !element.classList.contains('done');
            element.classList.toggle('done');

            // Update counter
            if (isNowDone) {
                completed++;
            } else {
                completed--;
            }

            document.getElementById('completed-count').innerText = completed;
            document.getElementById('bar-fill').style.width = (completed / total * 100) + '%';

            // SAVE TO DATABASE INSTANTLY
            try {
                await fetch('/api/mechanic/check-task', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ taskId, isCompleted: isNowDone })
                });

                // Notify Owner's Live Tracker
                socket.emit('task_update', { 
                    jobId: '<%= job.id %>', 
                    progress: (completed / total * 100) 
                });

                // Play success sound
                new Audio('https://assets.mixkit.co/active_storage/sfx/2571/2571-preview.mp3').play();
            } catch (err) {
                console.error('Failed to update task:', err);
                // Revert UI if save failed
                element.classList.toggle('done');
                completed += isNowDone ? -1 : 1;
                document.getElementById('completed-count').innerText = completed;
                document.getElementById('bar-fill').style.width = (completed / total * 100) + '%';
            }
        }

        window.onload = loadChecklist;
    </script>
</body>
</html>