<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mechanic Portal | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/alert.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/alert.js"></script>
    <style>
        /* MECHANIC-SPECIFIC STYLING */
        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(30px); }
            to { opacity: 1; transform: translateX(0); }
        }
        .animate-card { animation: slideInRight 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
        
        .mech-header {
            background: #0f172a; color: white; padding: 30px 20px;
            border-radius: 0 0 30px 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .stat-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-top: 20px; }
        .stat-pill-dark {
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
            padding: 12px; border-radius: 16px; text-align: center;
        }

        /* Duty Toggle Button */
        .duty-status {
            display: flex; align-items: center; gap: 8px; padding: 6px 14px;
            border-radius: 20px; font-size: 12px; font-weight: 800; border: none; cursor: pointer;
            transition: 0.3s;
        }
        .online { background: #22c55e; color: white; box-shadow: 0 0 15px rgba(34, 197, 94, 0.4); }
        .offline { background: #64748b; color: white; }

        /* Job Tabs */
        .tab-bar {
            display: flex; gap: 10px; margin: 20px 0; background: #e2e8f0;
            padding: 5px; border-radius: 14px;
        }
        .tab-item {
            flex: 1; padding: 10px; border: none; border-radius: 10px;
            font-size: 13px; font-weight: 700; color: #64748b; cursor: pointer; transition: 0.3s;
        }
        .tab-item.active { background: white; color: var(--primary-blue); box-shadow: 0 4px 10px rgba(0,0,0,0.05); }

        .job-card-mech {
            background: white; border-radius: 20px; padding: 20px; margin-bottom: 15px;
            border: 1px solid #e2e8f0; position: relative; overflow: hidden;
        }
        .price-tag { color: var(--action-orange); font-weight: 800; font-size: 16px; }

        .stat-card-luxury {
            background: rgba(255,255,255,0.03);
            border: 1.5px solid rgba(255,255,255,0.08);
            border-radius: 18px; padding: 15px; text-align: center;
            transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .stat-card-luxury:hover {
            background: rgba(255,255,255,0.08);
            border-color: var(--action-orange);
            transform: translateY(-5px);
        }
        .stat-card-luxury p { font-size: 9px; font-weight: 900; opacity: 0.5; margin-bottom: 5px; }
        .stat-card-luxury strong { font-size: 20px; font-family: 'Inter', sans-serif; }
    </style>
</head>

<body>
    <!-- TOP HEADER -->
    <header class="mech-header">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 25px;">
            <div>
                <p style="opacity: 0.6; font-size: 11px; font-weight: 800; letter-spacing: 1px;">MECHANIC PORTAL</p>
                <h2 style="font-size: 26px; font-weight: 900;"><%= userName %></h2>
            </div>
            <button id="duty-toggle" class="duty-status online animate-pop" onclick="toggleDuty()">
                <i data-lucide="power"></i> <span id="status-text">Online</span>
            </button>
        </div>

        <!-- NEW PROFESSIONAL STATS GRID -->
        <div class="stat-grid">
            <div class="stat-card-luxury">
                <p>TOTAL JOBS</p>
                <strong id="stat-total-jobs" style="color: #22c55e;">0</strong>
            </div>
            <div class="stat-card-luxury">
                <p>ACTIVE</p>
                <strong id="stat-active-jobs" style="color: #3b82f6;">0</strong>
            </div>
            <div class="stat-card-luxury">
                <p>RATING</p>
                <strong id="stat-avg-rating" style="color: #fbbf24;">0.0 ★</strong>
            </div>
        </div>
    </header>

    <!-- SEARCH & FILTER SECTION -->
    <div style="padding: 15px 20px; background: white; border-bottom: 1px solid #e2e8f0;">
        <div class="input-elegant-group" style="margin: 0; background: #f1f5f9;">
            <i data-lucide="search" size="18" color="#94a3b8"></i>
            <input type="text" id="dashboardSearch" placeholder="Search Plate or Job ID..." oninput="filterJobs()">
        </div>
    </div>

    <div style="padding: 0 20px;">
        <!-- TAB NAVIGATION -->
        <div class="tab-bar">
            <button class="tab-item" onclick="switchTab('sos', 0)">SOS <span id="badge-sos" class="badge" style="background: var(--emergency-red); color: white; padding: 2px 6px; border-radius: 6px; font-size: 10px;">0</span></button>
            <button class="tab-item" onclick="switchTab('bookings', 1)">Bookings <span id="badge-bookings" class="badge" style="background: #3b82f6; color: white; padding: 2px 6px; border-radius: 6px; font-size: 10px;">0</span></button>
            <button class="tab-item active" onclick="switchTab('active', 2)">Active <span id="badge-active" class="badge" style="background: #22c55e; color: white; padding: 2px 6px; border-radius: 6px; font-size: 10px;">0</span></button>
            <button class="tab-item" onclick="switchTab('history', 3)">History</button>
        </div>

        <!-- DYNAMIC JOB SECTIONS -->
        <div id="dashboard-content" style="padding: 20px;">
            <!-- Sections will be injected here -->
        </div>
    </div>

    <!-- MECHANIC BOTTOM NAV -->
    <nav class="bottom-nav">
        <a href="/mechanic/dashboard" class="nav-item active"><i data-lucide="layout-grid"></i><span>Jobs</span></a>
        <a href="/mechanic/profile" class="nav-item"><i data-lucide="user"></i><span>Profile</span></a>
        <a href="/logout" class="nav-item"><i data-lucide="log-out"></i><span>Logout</span></a>
    </nav>

    <!-- PARTS APPROVAL MODAL -->
    <div id="quote-modal" class="modal-overlay" style="display: none; align-items: flex-end; padding: 0;">
        <div class="animate-slide-up" style="background: white; width: 100%; padding: 30px 20px; border-radius: 30px 30px 0 0;">
            <h3 style="margin-bottom: 5px;">Part Approval Needed</h3>
            <p style="color: #64748b; font-size: 13px; margin-bottom: 25px;">Your mechanic says this part needs replacement.</p>
            
            <div style="display: flex; gap: 15px; background: #f8fafc; padding: 15px; border-radius: 15px; border: 1px solid #e2e8f0;">
                <div id="quote-photo" style="width: 80px; height: 80px; background: #cbd5e1; border-radius: 10px; overflow: hidden;">
                    <!-- Image filled via JS -->
                </div>
                <div style="flex: 1;">
                    <h4 id="quote-name" style="margin: 0;">Brake Pads</h4>
                    <p id="quote-price" style="color: var(--action-orange); font-weight: 800; font-size: 18px; margin-top: 5px;">UGX 85,000</p>
                </div>
            </div>

            <div style="display: flex; gap: 10px; margin-top: 30px;">
                <button onclick="respondQuote('reject')" class="btn-outline" style="flex: 1; border-color: #fecaca; color: #ef4444;">Reject</button>
                <button onclick="respondQuote('approve')" class="btn-primary" style="flex: 2;">Approve & Purchase</button>
            </div>
        </div>
    </div>

    <!-- RATING & COMPLETION MODAL -->
    <div id="finish-modal" class="modal-overlay" style="display: none; align-items: center;">
        <div class="animate-pop-in" style="background: white; width: 90%; max-width: 400px; padding: 35px; border-radius: 30px; text-align: center;">
            <div style="color: #22c55e;"><i data-lucide="check-circle" size="64"></i></div>
            <h2 style="margin-top: 20px;">Service Complete!</h2>
            <p style="color: #64748b; margin-top: 10px;">Your car is ready for pickup.</p>
            
            <h3 id="final-total" style="font-size: 28px; margin: 20px 0; color: var(--primary-blue);">UGX 135,000</h3>

            <a id="receipt-link" href="#" target="_blank" class="btn-outline" style="display: block; text-decoration: none; margin-bottom: 25px;">
                <i data-lucide="file-text" size="18"></i> Download PDF Receipt
            </a>

            <p class="label-text">RATE YOUR MECHANIC</p>
            <div style="display: flex; justify-content: center; gap: 10px; margin: 15px 0;">
                <i data-lucide="star" class="star-rating" onclick="setRating(1)"></i>
                <i data-lucide="star" class="star-rating" onclick="setRating(2)"></i>
                <i data-lucide="star" class="star-rating" onclick="setRating(3)"></i>
                <i data-lucide="star" class="star-rating" onclick="setRating(4)"></i>
                <i data-lucide="star" class="star-rating" onclick="setRating(5)"></i>
            </div>

            <button onclick="closeFinishModal()" class="btn-primary" style="width: 100%; border-radius: 15px;">Finish & Close</button>
        </div>
    </div>

    <style>
        .star-rating { color: #cbd5e1; cursor: pointer; transition: 0.2s; }
        .star-rating.active { color: #fbbf24; fill: #fbbf24; transform: scale(1.2); }
    </style>

    <script>
        lucide.createIcons();
        const socket = io();

        // 1. ONLINE/OFFLINE TOGGLE (Updated with API call)
        let isOnline = true;
        async function toggleDuty() {
            isOnline = !isOnline;
            const btn = document.getElementById('duty-toggle');
            const text = document.getElementById('status-text');
            
            if (isOnline) {
                btn.className = "duty-status online";
                text.innerText = "Online";
            } else {
                btn.className = "duty-status offline";
                text.innerText = "Offline";
            }

            // Save status to database
            await fetch('/api/mechanic/toggle-status', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ isOnline })
            });

            // Notify server via socket to join/leave online_mechanics room
            socket.emit('mechanic_status_changed', { isOnline });
        }

        let currentTab = 'active';

        // 2. TAB SWITCHING LOGIC
        async function switchTab(type, index) {
            currentTab = type;
            const tabs = document.querySelectorAll('.tab-item');
            tabs.forEach(t => t.classList.remove('active'));
            tabs[index].classList.add('active');
            
            if(type === 'done') {
                const res = await fetch('/api/mechanic/all-jobs');
                const data = await res.json();
                renderSection(data.history, 'dynamic-history-container'); // This uses your Today/Yesterday/Older grouping
            } else {
                refreshDashboard(); // Reload jobs for the selected tab
            }
        }

        // 3. DYNAMIC RENDERER WITH GROUPING & ACCENTS
        function renderSection(groupedJobs, containerId = 'dashboard-content') {
            const container = document.getElementById(containerId);
            container.innerHTML = '';

            // Standard categories
            const timeframes = ['Today', 'Yesterday', 'This Week', 'Last Week', 'Last Month', 'Older'];

            // Group the specific tab's jobs by date
            const sections = groupJobsByDate(groupedJobs); 

            timeframes.forEach(time => {
                if (!sections[time] || sections[time].length === 0) return;

                // Date Header
                const header = document.createElement('h5');
                header.className = "section-label animate-item";
                header.style = "margin: 25px 0 15px 0; color: #64748b;";
                header.innerText = time;
                container.appendChild(header);

                sections[time].forEach(job => {
                    const card = currentTab === 'history' ? renderHistoryCard(job) : renderJobCard(job);
                    container.appendChild(card);
                });
            });
            lucide.createIcons();
        }

        // RENDER JOB CARD - Extracted for reusability
        function renderJobCard(job) {
            const card = document.createElement('div');
            const accentColor = job.sos_active ? "#ef4444" : "#3b82f6"; // Red for SOS, Blue for Booking
            
            card.className = "job-card-mech animate-item";
            card.style.borderLeft = `6px solid ${accentColor}`;
            card.setAttribute('data-search', `${job.plate_number} ${job.id}`.toLowerCase());

            card.innerHTML = `
                <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                    <div>
                        <span style="font-size:10px; font-weight:800; color:#94a3b8;">JOB ID: #${job.id}</span>
                        <h4 style="margin:2px 0;">${job.owner_name}</h4>
                        <p style="font-size:12px; font-weight:700; color:${accentColor};">${job.plate_number}</p>
                    </div>
                    <span class="status-badge" style="background:${accentColor}15; color:${accentColor}; border:1px solid ${accentColor}30;">
                        ${job.sos_active ? 'SOS' : 'BOOKING'}
                    </span>
                </div>

                <div style="margin: 15px 0; padding: 12px; background: #f8fafc; border-radius: 12px;">
                    <p style="font-size:11px; color:#94a3b8; font-weight:800;">CURRENT TASK</p>
                    <span style="font-size:14px; font-weight:600;">${job.service_type}</span>
                </div>

                <!-- ACTION BUTTONS -->
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
                    <a href="tel:${job.owner_phone}" class="btn-outline" style="padding:10px; border-radius:10px; text-align:center; text-decoration:none; font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; gap:5px;">
                        <i data-lucide="phone" size="14"></i> Call
                    </a>
                    <a class="btn-navigate btn-outline" target="_blank" style="padding:10px; border-radius:10px; text-align:center; text-decoration:none; font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; gap:5px;">
                        <i data-lucide="map-pin" size="14"></i> Navigate
                    </a>
                    <button class="btn-primary" style="grid-column: span 2; margin-top:5px; background:${job.sos_active ? '#ef4444' : '#0f172a'};">
                        ${job.status === 'accepted' ? 'Start Diagnosis' : 'Update Job Card'}
                    </button>
                </div>
            `;

            // Use the lat/lng sent directly from the owner's browser
            const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${job.location_lat},${job.location_lng}`;
            card.querySelector('.btn-navigate').href = mapsUrl;

            // Ensure SOS jobs are explicitly accepted, not automatic
            const primaryBtn = card.querySelector('.btn-primary');
            if (job.sos_active && job.status === 'pending') {
                primaryBtn.textContent = 'Accept SOS';
                primaryBtn.onclick = function () {
                    acceptJob(job.id);
                };
            } else {
                primaryBtn.onclick = function () {
                    location.href = '/mechanic/job/' + job.id;
                };
            }

            return card;
        }

        // --- UPDATED RENDERER FOR HISTORY TAB ---
        function renderHistoryCard(job) {
            const card = document.createElement('div');
            card.className = "job-card-mech history-card animate-item";
            
            // Greyed out look for history
            card.style.borderLeft = "6px solid #64748b";
            card.style.opacity = "0.9";
            card.setAttribute('data-search', `${job.plate_number} ${job.id}`.toLowerCase());

            card.innerHTML = `
                <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                    <div>
                        <span style="font-size:10px; font-weight:800; color:#94a3b8;">PAID RECORD • ID: #${job.id}</span>
                        <h4 style="margin:2px 0; color:#1e293b;">${job.owner_name}</h4>
                        <p style="font-size:12px; font-weight:600; color:#64748b;">${job.make} ${job.model} (${job.plate_number})</p>
                    </div>
                    <div style="text-align:right;">
                        <span class="status-badge" style="background:#f1f5f9; color:#64748b;">FINISHED</span>
                        <p style="color:#16a34a; font-weight:900; margin-top:5px;">UGX ${Number(job.total_price).toLocaleString()}</p>
                    </div>
                </div>

                <div style="margin: 15px 0; padding: 12px; background: #f8fafc; border-radius: 12px; border: 1px solid #f1f5f9;">
                    <p style="font-size:10px; color:#94a3b8; font-weight:800;">SERVICE RENDERED</p>
                    <span style="font-size:13px; font-weight:600; color:#475569;">${job.service_type}</span>
                </div>

                <!-- VIEW SUMMARY INSTEAD OF UPDATE -->
                <button onclick="location.href='/mechanic/job/${job.id}'" class="btn-primary" style="width:100%; background:#0f172a; border-radius:12px; font-weight:800;">
                    <i data-lucide="eye" size="16"></i> View Service Summary
                </button>
            `;
            return card;
        }

        // 4. SEARCH FILTER LOGIC
        function filterJobs() {
            const query = document.getElementById('dashboardSearch').value.toLowerCase();
            const cards = document.querySelectorAll('.job-card-mech');
            cards.forEach(card => {
                const text = card.getAttribute('data-search');
                card.style.display = text.includes(query) ? 'block' : 'none';
            });
        }

        // 5. DATE GROUPING LOGIC (CLIENT SIDE)
        function groupJobsByDate(jobs) {
            const groups = { Today: [], Yesterday: [], 'This Week': [], 'Last Week': [], 'Last Month': [], Older: [] };
            const now = new Date();
            jobs.forEach(job => {
                const date = new Date(job.created_at);
                const diff = Math.floor((now - date) / (1000 * 60 * 60 * 24));
                if (diff === 0) groups.Today.push(job);
                else if (diff === 1) groups.Yesterday.push(job);
                else if (diff < 7) groups['This Week'].push(job);
                else if (diff < 30) groups['Last Month'].push(job);
                else groups.Older.push(job);
            });
            return groups;
        }

        // Listen for the quote from the mechanic
        socket.on('new_quote_alert', (data) => {
            // Only show if it belongs to this owner
            if (data.ownerId == '<%= userId %>') {
                document.getElementById('quote-name').innerText = data.partName;
                document.getElementById('quote-price').innerText = "UGX " + data.price;
                document.getElementById('quote-modal').style.display = 'flex';
                
                // Play a notification sound
                new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3').play();
            }
        });

        function respondQuote(decision) {
            // Close modal and notify server
            document.getElementById('quote-modal').style.display = 'none';
            socket.emit('quote_response', { decision: decision });
            alert(decision === 'approve' ? "Part approved! Repair will continue." : "Part rejected.");
        }

        // Listen for job finished event
        socket.on('job_finished', (data) => {
            if (data.ownerId == '<%= userId %>') {
                document.getElementById('final-total').innerText = "UGX " + data.total.toLocaleString();
                document.getElementById('receipt-link').href = data.receiptUrl;
                document.getElementById('finish-modal').style.display = 'flex';
                
                // Success sound
                new Audio('https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3').play();
            }
        });

        function setRating(n) {
            const stars = document.querySelectorAll('.star-rating');
            stars.forEach((s, i) => {
                i < n ? s.classList.add('active') : s.classList.remove('active');
            });
        }

        function closeFinishModal() {
            document.getElementById('finish-modal').style.display = 'none';
            location.reload(); // Refresh to clear the active job bar
        }

        // Listen for real-time job updates
        socket.on('new_job_pushed', (job) => {
            if (isOnline) {
                refreshDashboard(); // always refresh when a new job is pushed
                new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3').play();
            }
        });

        // 3. Load all jobs on page load
        window.onload = async () => {
            await loadStats();
            await refreshDashboard();
        };

        // Load mechanic stats
        async function loadStats() {
            try {
                const res = await fetch('/api/mechanic/stats');
                const stats = await res.json();
                
                document.getElementById('stat-total-jobs').innerText = stats.totalJobs;
                document.getElementById('stat-active-jobs').innerText = stats.activeJobs;
                document.getElementById('stat-avg-rating').innerText = stats.rating + ' ★';
            } catch (err) {
                console.error('Error loading stats:', err);
            }
        }

        function acceptJob(jobId) {
            socket.emit('accept_job', { jobId });
            
            AppAlert.show(
                "Job Accepted!", 
                "Please drive safely to the owner's location. Contact them if you need directions.", 
                "success"
            );
            refreshDashboard();
        }

        // Respond to Appointment (Accept/Decline)
        async function respondApp(jobId, decision) {
            const res = await fetch('/api/mechanic/respond-appointment', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ jobId, decision })
            });
            const data = await res.json();
            if(data.success) {
                AppAlert.show(decision === 'accepted' ? "Confirmed!" : "Declined", "Owner has been notified.", "success");
                refreshDashboard();
            }
        }

        async function refreshDashboard() {
            try {
                const res = await fetch('/api/mechanic/all-jobs');
                const groupedJobs = await res.json();
                
                // Update badge counts
                document.getElementById('badge-sos').innerText = groupedJobs.sos?.length || 0;
                document.getElementById('badge-bookings').innerText = groupedJobs.bookings?.length || 0;
                document.getElementById('badge-active').innerText = groupedJobs.active?.length || 0;
                
                // Get the jobs for the current tab
                let tabJobs = [];
                if (currentTab === 'sos') {
                    tabJobs = groupedJobs.sos || [];
                } else if (currentTab === 'bookings') {
                    tabJobs = groupedJobs.bookings || [];
                } else if (currentTab === 'active') {
                    tabJobs = groupedJobs.active || [];
                } else if (currentTab === 'history') {
                    tabJobs = groupedJobs.history || [];
                }
                
                // Render the section with grouping and filtering
                renderSection(tabJobs);
                
                // Load updated stats
                await loadStats();
            } catch (err) {
                console.error('Error refreshing dashboard:', err);
            }
        }
    </script>
</body>
</html>