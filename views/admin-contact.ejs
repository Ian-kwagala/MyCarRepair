<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-wrapper">
    <div class="auth-card animate-pop-in" style="padding: 40px; text-align: center;">
        <div style="color: var(--action-orange);"><i data-lucide="shield-alert" size="48"></i></div>
        <h2 style="margin: 20px 0;">Account Recovery</h2>
        <p style="color: #64748b; line-height: 1.6;">For security reasons, password resets are handled by the system administrator.</p>
        
        <div style="background: #f1f5f9; padding: 20px; border-radius: 15px; margin: 25px 0; text-align: left;">
            <p style="font-size: 11px; font-weight: 800; color: #94a3b8;">CONTACT ADMIN</p>
            <p style="font-weight: 700; color: #1e293b; margin-top: 5px;">📞 +256 700 000 000</p>
            <p style="font-weight: 700; color: #1e293b;">📧 admin@mycarrepair.com</p>
        </div>

        <button onclick="history.back()" class="btn-primary" style="width: 100%;">Back to Login</button>
    </div>
    <script src="https://unpkg.com/lucide@latest"></script><script>lucide.createIcons();</script>
</body>
</html>