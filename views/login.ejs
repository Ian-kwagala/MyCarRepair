<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/alerts.css">
    <script src="/js/alerts.js"></script>
    <!-- This line adds the icon to the browser tab -->
<link rel="icon" type="image/png" href="/images/favicon.png">
</head>
<body class="auth-page">

<div class="auth-card">
    <div class="auth-header">
        <!-- Role Toggle -->
        <div class="role-container">
            <button class="role-tab active" id="tab-owner" onclick="setRole('owner')">
                    <i data-lucide="car" size="18"></i> Owner
                </button>
                <button class="role-tab" id="tab-mechanic" onclick="setRole('mechanic')">
                    <i data-lucide="wrench" size="18"></i> Mechanic
                </button>
        </div>
        <h2 id="display-title" style="font-weight: 900; letter-spacing: -1px;">Welcome Back</h2>
        <p id="display-desc" style="opacity: 0.8; font-size: 14px; margin-top: 5px;">Find trusted mechanics near you</p>
    </div>

    <form action="/auth/login" method="POST" style="padding: 30px;">
        <input type="hidden" name="role" id="userRole" value="owner">

        <span class="label-mini">Email Address</span>
        <div class="input-row">
            <i data-lucide="mail" size="18" color="#94a3b8"></i>
            <input type="email" name="email" placeholder="you@email.com" required>
        </div>

        <span class="label-mini">Password</span>
        <div class="input-row">
            <i data-lucide="lock" size="18" color="#94a3b8"></i>
            <input type="password" id="login-pass" name="password" placeholder="••••••••" required>
            <div style="cursor:pointer;" onclick="togglePassword('login-pass')">
                <i data-lucide="eye" size="18" color="#94a3b8" id="eye-icon"></i>
            </div>
        </div>

        <div style="text-align: right; margin-top: -6px; margin-bottom: 16px;">
            <a href="/admin-contact" style="font-size: 12px; color: #64748b; text-decoration: none; font-weight: 700;">Forgot Password?</a>
        </div>

        <button type="submit" class="btn-primary" style="width: 100%; padding: 18px; border-radius: 16px; font-weight: 800; font-size: 16px;">
            Sign In
        </button>

        <p style="text-align: center; margin-top: 25px; font-size: 14px; color: #64748b;">
            Don't have an account? <a href="/signup" style="color: #F97316; font-weight: 800; text-decoration: none;">Sign Up</a>
        </p>
    </form>
</div>

<script>
    lucide.createIcons();

    function setRole(role) {
        document.getElementById('userRole').value = role;
        const title = document.getElementById('display-title');
        const desc = document.getElementById('display-desc');
        const tabO = document.getElementById('tab-owner');
        const tabM = document.getElementById('tab-mechanic');

        if (role === 'mechanic') {
            title.innerText = 'Mechanic Login';
            desc.innerText = 'Access your garage dashboard and manage jobs';
            tabM.classList.add('active');
            tabO.classList.remove('active');
        } else {
            title.innerText = 'Welcome Back';
            desc.innerText = 'Find trusted mechanics near you';
            tabO.classList.add('active');
            tabM.classList.remove('active');
        }
    }

    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        if (!input) {
            return;
        }

        if (input.type === 'password') {
            input.type = 'text';
            document.getElementById('eye-icon').setAttribute('data-lucide', 'eye-off');
        } else {
            input.type = 'password';
            document.getElementById('eye-icon').setAttribute('data-lucide', 'eye');
        }
        lucide.createIcons();
    }
</script>

<link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
</body>
</html>