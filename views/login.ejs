<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/alerts.css">
<script src="/js/alerts.js"></script>
</head>
<body>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <!-- Role Toggle -->
            <div class="role-toggle">
                <button class="role-btn active" onclick="setRole('owner')">
                    <i data-lucide="car"></i> Car Owner
                </button>
                <button class="role-btn" onclick="setRole('mechanic')">
                    <i data-lucide="wrench"></i> Mechanic
                </button>
            </div>
            <h2>Welcome Back</h2>
            <p style="font-size: 0.9rem; opacity: 0.8;">Find trusted mechanics near you</p>
        </div>

        <div class="login-body">
            <form action="/auth/login" method="POST">
                <!-- Hidden input to track if logging in as owner or mechanic -->
                <input type="hidden" name="role" id="userRole" value="owner">

                <div class="form-group">
                    <label>Email</label>
                    <div class="input-wrapper">
                        <i data-lucide="mail" size="18"></i>
                        <input type="email" name="email" placeholder="you@email.com" required>
                    </div>
                </div>

                <!-- Inside Login Body -->
                <div class="original-input-box">
                    <i data-lucide="lock" size="18" color="#94a3b8"></i>
                    <input type="password" id="login-pass" name="password" placeholder="••••••••" required>
                    <i data-lucide="eye" class="eye-icon" onclick="togglePassword('login-pass')"></i>
                </div>

                <!-- FEATURE 4: FORGOT PASSWORD -->
                <div style="text-align: right; margin: -5px 0 20px 0;">
                    <a href="/admin-contact" style="font-size: 12px; color: #64748b; text-decoration: none; font-weight: 600;">Forgot Password?</a>
                </div>

                <button type="submit" class="btn-primary" style="width: 100%; justify-content: center;">
                    Sign In
                </button>
            </form>
            
            <p style="text-align: center; margin-top: 20px; font-size: 14px;">
                Don't have an account? <a href="/signup" style="color: var(--action-orange); font-weight: bold; text-decoration: none;">Sign Up</a>
            </p>
        </div>
    </div>
</div>

<script>
    lucide.createIcons();

    // Function to handle the toggle button switch
    function setRole(role) {
        document.getElementById('userRole').value = role;
        
        // Update UI button colors
        const buttons = document.querySelectorAll('.role-btn');
        buttons.forEach(btn => btn.classList.remove('active'));
        
        if(role === 'owner') {
            buttons[0].classList.add('active');
        } else {
            buttons[1].classList.add('active');
        }
    }

    // Password toggle function
    function togglePassword(id) {
        const input = document.getElementById(id);
        const icon = event.target;
        if(input.type === 'password') {
            input.type = 'text';
            icon.setAttribute('data-lucide', 'eye-off');
        } else {
            input.type = 'password';
            icon.setAttribute('data-lucide', 'eye');
        }
        lucide.createIcons();
    }
</script>

</body>
</html>