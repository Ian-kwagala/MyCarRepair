<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><title>User Management | Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/alerts.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/js/alerts.js"></script>
    <style>
        :root {
            --admin-bg: #f8fafc;
            --admin-surface: rgba(255, 255, 255, 0.9);
            --admin-border: #e2e8f0;
            --admin-muted: #64748b;
            --admin-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
        }

        body {
            margin: 0;
            background: var(--admin-bg);
            color: #0f172a;
            display: flex;
        }

        .main-content {
            flex: 1;
            padding: 40px;
            margin-left: 250px;
            min-height: 100vh;
            position: relative;
            overflow: hidden;
        }

        .page-shell {
            position: relative;
            z-index: 1;
        }

        .page-hero {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            margin-bottom: 28px;
        }

        .page-title {
            margin: 0;
            font-size: clamp(2rem, 4vw, 3.2rem);
            letter-spacing: -0.04em;
            line-height: 1;
        }

        .page-copy {
            margin: 10px 0 0;
            color: var(--admin-muted);
            max-width: 60ch;
        }

        .input-elegant-group {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 16px;
            border: 1px solid var(--admin-border);
            background: white;
            box-shadow: var(--admin-shadow);
        }

        .input-elegant-group input {
            border: 0;
            outline: 0;
            width: 100%;
            background: transparent;
            font: inherit;
        }

        .tab-bar {
            display: flex;
            gap: 8px;
            padding: 6px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.72);
            border: 1px solid rgba(226, 232, 240, 0.9);
            box-shadow: var(--admin-shadow);
            backdrop-filter: blur(10px);
        }

        .tab-item {
            display: block;
            flex: 1;
            padding: 12px 14px;
            border: 0;
            border-radius: 12px;
            background: transparent;
            font-size: 13px;
            font-weight: 800;
            color: #64748b;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            transition: transform 180ms ease, background 180ms ease, color 180ms ease, box-shadow 180ms ease;
        }

        .tab-item:hover {
            transform: translateY(-1px);
        }

        .tab-item.active {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: white;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.14);
        }

        .user-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--admin-surface);
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid rgba(226, 232, 240, 0.92);
            box-shadow: var(--admin-shadow);
            backdrop-filter: blur(10px);
        }

        .user-table th {
            background: #f8fafc;
            padding: 16px 20px;
            text-align: left;
            font-size: 11px;
            color: #94a3b8;
            letter-spacing: 0.16em;
            text-transform: uppercase;
        }

        .user-table td {
            padding: 18px 20px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .user-table tbody tr {
            transition: background 180ms ease, transform 180ms ease;
        }

        .user-table tbody tr:hover {
            background: #f8fafc;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 8px;
            flex: 0 0 auto;
        }

        .btn-action {
            padding: 8px 10px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: white;
            cursor: pointer;
            transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease, color 180ms ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
        }

        .btn-action:hover {
            transform: translateY(-1px);
            background: #f8fafc;
            color: var(--action-orange);
            box-shadow: 0 10px 18px rgba(15, 23, 42, 0.08);
        }

        .user-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            color: #475569;
            flex: 0 0 auto;
        }

        .user-meta {
            display: grid;
            gap: 4px;
        }

        .user-name {
            font-size: 15px;
            font-weight: 800;
            color: #1e293b;
        }

        .status-badge,
        .role-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            width: fit-content;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .status-badge.is-active {
            background: #dcfce7;
            color: #166534;
        }

        .status-badge.is-suspended {
            background: #fee2e2;
            color: #991b1b;
        }

        .role-badge {
            background: #f1f5f9;
            color: #475569;
        }

        .empty-state {
            padding: 34px 16px;
            text-align: center;
            color: var(--admin-muted);
        }

        .floating-orb {
            position: fixed;
            right: 18px;
            bottom: 18px;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.14), transparent 70%);
            pointer-events: none;
            filter: blur(4px);
            animation: drift 8s ease-in-out infinite;
        }

        @keyframes drift {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(-8px, -14px); }
        }

        @media (max-width: 960px) {
            body {
                display: block;
            }

            .main-content {
                margin-left: 0;
                padding: 18px 14px 24px;
            }

            .page-hero {
                flex-direction: column;
                align-items: stretch;
            }

            .tab-bar {
                width: 100% !important;
            }
        }
    </style>
</head>
<body>

    <%- include('../partials/admin-sidebar') %>

    <% const safeUsers = Array.isArray(users) ? users : []; %>
    <% const safeFilter = typeof currentFilter !== 'undefined' ? currentFilter : 'all'; %>
    <% const safeSearch = typeof currentSearch !== 'undefined' ? currentSearch : ''; %>
    <% const filteredUsers = safeUsers.filter(user => safeFilter === 'all' ? true : String(user.role || '').toLowerCase() === safeFilter); %>

    <div class="main-content">
        <div class="page-shell">
            <div class="page-hero">
                <div>
                    <h1 class="page-title">User Management</h1>
                    <p class="page-copy">Search, filter, and manage account status from a consistent admin interface with the same polished motion and spacing used across the dashboard.</p>
                </div>
                <div class="input-elegant-group" style="width: 300px; background: white;">
                    <i data-lucide="search" size="18"></i>
                    <input type="text" id="userSearch" value="<%= safeSearch %>" placeholder="Search by name or email..." oninput="searchUsers()">
                </div>
            </div>

            <div class="tab-bar" style="margin-bottom: 20px; width: 400px; max-width: 100%;">
                <a class="tab-item <%= safeFilter === 'all' ? 'active' : '' %>" href="/admin/users?role=all&search=<%= encodeURIComponent(safeSearch) %>">All</a>
                <a class="tab-item <%= safeFilter === 'owner' ? 'active' : '' %>" href="/admin/users?role=owner&search=<%= encodeURIComponent(safeSearch) %>">Owners</a>
                <a class="tab-item <%= safeFilter === 'mechanic' ? 'active' : '' %>" href="/admin/users?role=mechanic&search=<%= encodeURIComponent(safeSearch) %>">Mechanics</a>
            </div>

            <table class="user-table animate-item">
                <thead>
                    <tr>
                        <th>User Details</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Activity</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="user-body">
                    <% if (filteredUsers.length === 0) { %>
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i data-lucide="users" size="36"></i>
                                    <p style="margin: 14px 0 0; font-weight: 800; color: #0f172a;">No users found</p>
                                    <p style="margin: 6px 0 0;">Try a different filter or search term.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>

                    <% filteredUsers.forEach(user => { %>
                        <% const userName = String(user.full_name || 'Unknown User'); %>
                        <% const userEmail = String(user.email || ''); %>
                        <% const userRole = String(user.role || 'user'); %>
                        <% const userStatus = String(user.status || 'active'); %>
                        <% const nextStatus = userStatus === 'suspended' ? 'active' : 'suspended'; %>
                        <% const avatarLetter = userName.charAt(0).toUpperCase(); %>
                        <% const isOnline = !!user.is_online; %>
                        <% const activityCount = userRole === 'owner' ? Number(user.vehicle_count || 0) : Number(user.activity_count || 0); %>
                        <% const activityLabel = userRole === 'owner' ? 'Cars' : 'Jobs'; %>
                        <% const rowSearch = (userName + ' ' + userEmail + ' ' + userRole).toLowerCase(); %>
                        <tr class="user-row" data-name="<%= userName.toLowerCase() %>" data-email="<%= userEmail.toLowerCase() %>" data-search="<%= rowSearch %>">
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div class="user-avatar"><%= avatarLetter %></div>
                                    <div class="user-meta">
                                        <strong class="user-name"><%= userName %></strong>
                                        <span style="font-size: 12px; color: #94a3b8;"><%= userEmail %></span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="role-badge"><%= userRole.toUpperCase() %></span>
                            </td>
                            <td>
                                <div style="display: flex; align-items: center;">
                                    <span class="status-dot" style="background: <%= isOnline ? '#22c55e' : '#cbd5e1' %>"></span>
                                    <span class="status-badge <%= userStatus === 'suspended' ? 'is-suspended' : 'is-active' %>">
                                        <%= userStatus.toUpperCase() %>
                                    </span>
                                </div>
                            </td>
                            <td>
                                <span style="font-size: 12px; font-weight: 700; color: #64748b;">
                                    <%= activityCount %> <%= activityLabel %>
                                </span>
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                                    <button class="btn-action" title="Edit User" onclick="location.href='/admin/edit-user/<%= user.id %>'"><i data-lucide="edit-2" size="16"></i></button>

                                    <% if (userStatus === 'suspended') { %>
                                        <button class="btn-action" style="color: #22c55e;" onclick="updateStatus(<%= user.id %>, 'active')"><i data-lucide="user-check" size="16"></i></button>
                                    <% } else { %>
                                        <button class="btn-action" style="color: #ef4444;" onclick="updateStatus(<%= user.id %>, 'suspended')"><i data-lucide="user-x" size="16"></i></button>
                                    <% } %>

                                    <button class="btn-action" style="color: #64748b;" onclick="deleteUser(<%= user.id %>)"><i data-lucide="trash-2" size="16"></i></button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="floating-orb"></div>

    <script>
        lucide.createIcons();

        function searchUsers() {
            const query = document.getElementById('userSearch').value.toLowerCase().trim();
            document.querySelectorAll('.user-row').forEach(row => {
                const searchText = (row.getAttribute('data-search') || '').toLowerCase();
                row.style.display = searchText.includes(query) ? 'table-row' : 'none';
            });
        }

        function updateStatus(userId, newStatus) {
            const action = newStatus === 'suspended' ? 'SUSPEND' : 'ACTIVATE';
            AppAlert.confirm(`${action} User?`, `Are you sure you want to set this user to ${newStatus}?`, async () => {
                const res = await fetch('/api/admin/user/status', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ userId, newStatus })
                });

                if (res.ok) {
                    location.reload();
                    return;
                }

                AppAlert.show('Update Failed', 'Unable to update this user right now.', 'error');
            });
        }

        function deleteUser(userId) {
            AppAlert.confirm('DANGER!', 'This will permanently delete this user and all their data. Proceed?', async () => {
                const res = await fetch('/api/admin/user/delete', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ userId })
                });

                if (res.ok) {
                    location.reload();
                    return;
                }

                AppAlert.show('Delete Failed', 'Unable to delete this user right now.', 'error');
            });
        }
    </script>
</body>
</html>