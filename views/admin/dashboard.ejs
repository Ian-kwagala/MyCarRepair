<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><title>Admin Command Center</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        /* Layout and main container styles */
        .sidebar { width: 250px; background: #0f172a; height: 100vh; position: fixed; color: white; padding: 20px; }
        .main-content { margin-left: 250px; padding: 40px; background: #f8fafc; min-height: 100vh; }
        
        /* Stat card styling for admin dashboard metrics */
        .stat-card-admin { background: white; padding: 20px 22px; border-radius: 14px; box-shadow: 0 2px 8px rgba(15,23,42,0.04); }
        .stat-card-admin .kpi-meta { display: flex; align-items: center; gap: 10px; font-size: 13px; color: #64748b; }
        .kpi-trend { font-weight: 700; font-size: 12px; display: inline-flex; align-items: center; gap: 6px; }
        .kpi-trend.up { color: #16a34a; }
        .kpi-trend.down { color: #ef4444; }
        .sparkline { height: 28px; width: 100px; opacity: 0.9; }
        
        /* Maintenance mode alert banner */
        .maintenance-banner { background: #fee2e2; border: 2px solid #ef4444; padding: 20px; border-radius: 15px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; }
        
        /* Admin specific status badge styles with color-coded states */
        .status-badge { 
            padding: 4px 10px; 
            border-radius: 6px; 
            font-size: 10px; 
            font-weight: 800; 
            text-transform: uppercase; 
        }
        .status-pending { background: #fff7ed; color: #c2410c; }    /* Orange: Searching/Pending */
        .status-accepted { background: #eff6ff; color: #1d4ed8; }   /* Blue: Moving/In Progress */
        .status-fixing { background: #f0fdf4; color: #15803d; }     /* Green: Started/Active */
        .status-completed { background: #f1f5f9; color: #475569; }  /* Grey: Completed/Done */

        /* Live pulse indicator for real-time status */
        .pulse-dot {
            width: 10px; 
            height: 10px; 
            background: #22c55e; 
            border-radius: 50%;
            box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); 
            animation: pulseAdmin 2s infinite;
        }

        .mechanic-indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex: 0 0 auto;
        }

        .mechanic-indicator.online {
            background: #22c55e;
        }

        .mechanic-indicator.offline {
            background: #cbd5e1;
        }

        .job-log-btn {
            background: none;
            border: none;
            color: var(--primary-blue);
            cursor: pointer;
            padding: 0;
            transition: transform 180ms ease, color 180ms ease;
        }

        .job-log-btn:hover {
            transform: translateY(-1px);
            color: #1d4ed8;
        }
        
        /* Pulse animation for live indicator */
        @keyframes pulseAdmin {
            70% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
            100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
        }

        /* Small responsive rules */
        @media (max-width: 900px) {
            .main-content { padding: 20px; margin-left: 0; }
            .sidebar { position: fixed; transform: translateX(-260px); transition: transform .22s ease; }
            .sidebar.open { transform: translateX(0); }
            .stat-grid { grid-template-columns: 1fr; }
            .live-table { overflow-x: auto; }
        }
    </style>
</head>
<body>
    <!-- Safe variable access using locals object (EJS best practice) -->
    <% 
        const systemStatus_value = locals.systemStatus || false;
        const revenue_value = locals.revenue || 0;
        const ownerStats_value = locals.ownerStats || { total: 0, online: 0, offline: 0 };
        const mechStats_value = locals.mechStats || { total: 0, online: 0, offline: 0 };
        const jobStats_value = locals.jobStats || { total: 0, active: 0, completed: 0 };
        const liveJobs_value = Array.isArray(locals.liveJobs) ? locals.liveJobs : [];
        const recentJobs_value = Array.isArray(locals.recentJobs) ? locals.recentJobs : [];
        const pending_value = Array.isArray(locals.pending) ? locals.pending : [];
    %>

    <script id="dashboard-page-data" type="application/json"><%- JSON.stringify({
        revenue: Number(revenue_value),
        jobTotal: Number(jobStats_value.total),
        liveJobs: liveJobs_value.map((job) => ({
            id: job.id,
            status: job.status,
            owner_name: job.owner_name,
            mechanic_name: job.mechanic_name,
            mechanic_online: !!job.mechanic_online,
            service_type: job.service_type,
            updated_at: job.updated_at
        }))
    }) %></script>

    <div class="sidebar">
        <h2 style="color: var(--action-orange);">MyCarRepair</h2>
        <p style="font-size: 10px; opacity: 0.5; letter-spacing: 2px; margin-top: 5px;">ADMIN PANEL</p>
        <nav style="margin-top: 50px; display: flex; flex-direction: column; gap: 20px;">
            <a href="/admin/dashboard" style="color: white; text-decoration: none; font-weight: 800;"><i data-lucide="layout-dashboard"></i> Overview</a>
            <a href="/admin/users" style="color: #94a3b8; text-decoration: none;"><i data-lucide="users"></i> User Management</a>
            <a href="/admin/system" style="color: #94a3b8; text-decoration: none;"><i data-lucide="settings"></i> System Settings</a>
            <a href="/logout" style="color: #fca5a5; text-decoration: none; margin-top: 100px;"><i data-lucide="log-out"></i> Logout</a>
        </nav>
    </div>

    <div class="main-content">
        <!-- MAINTENANCE TOGGLE -->
        <% if (systemStatus_value) { %>
            <div class="maintenance-banner">
                <div>
                    <h4 style="color: #b91c1c;">⚠️ SYSTEM IS IN MAINTENANCE MODE</h4>
                    <p style="font-size: 13px; color: #7f1d1d;">Regular users cannot access their dashboards right now.</p>
                </div>
                <button onclick="toggleMaintenance(false)" class="btn-primary" style="background: #ef4444;">Disable Maintenance</button>
            </div>
        <% } %>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h1>System Overview</h1>
            <button onclick="toggleMaintenance(true)" class="btn-outline" style="border-color: #ef4444; color: #ef4444;">Enable System Maintenance</button>
        </div>

        <!-- TOP ROW: SYSTEM SUMMARY - Displays key metrics for platform health -->
        <div class="stat-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 18px; align-items: start;">
            
            <!-- REVENUE CARD - Total platform earnings -->
            <div class="stat-card-admin">
                <p class="label-text">TOTAL REVENUE</p>
                <h2 style="color: #16a34a; margin: 5px 0;">UGX <%= Number(revenue_value).toLocaleString() %></h2>
                <div class="kpi-meta">
                    <div class="kpi-trend" id="rev-trend">—</div>
                    <svg class="sparkline" id="rev-spark" viewBox="0 0 100 28" preserveAspectRatio="none"></svg>
                </div>
            </div>

            <!-- CAR OWNERS CARD - Active owner count and online status -->
            <div class="stat-card-admin">
                <p class="label-text">CAR OWNERS</p>
                <h2 style="margin: 5px 0;"><%= ownerStats_value.total %></h2>
                <div class="kpi-meta">
                    <div style="color: #22c55e;">● <%= ownerStats_value.online %> Online</div>
                    <div style="color: #94a3b8;"><%= ownerStats_value.offline %> Offline</div>
                </div>
            </div>

            <!-- MECHANICS CARD - Mechanic count and availability -->
            <div class="stat-card-admin">
                <p class="label-text">MECHANICS</p>
                <h2 style="margin: 5px 0;"><%= mechStats_value.total %></h2>
                <div class="kpi-meta">
                    <div style="color: #22c55e;">● <%= mechStats_value.online %> Online</div>
                    <div style="color: #94a3b8;"><%= mechStats_value.offline %> Offline</div>
                </div>
            </div>

            <!-- TOTAL JOBS CARD - Job statistics (active vs completed) -->
            <div class="stat-card-admin">
                <p class="label-text">TOTAL JOBS</p>
                <h2 style="margin: 5px 0;"><%= jobStats_value.total %></h2>
                <div class="kpi-meta">
                    <div style="color: #3b82f6;"><%= jobStats_value.active %> Active</div>
                    <div style="color: #16a34a;"><%= jobStats_value.completed %> Done</div>
                    <svg class="sparkline" id="jobs-spark" viewBox="0 0 100 28" preserveAspectRatio="none"></svg>
                </div>
            </div>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; gap:12px;">
            <div style="display:flex; gap:8px;">
                <a href="/admin/users?role=all" class="btn-outline" style="padding:8px 12px;">View Pending Users</a>
                <a href="/admin/dashboard#live" class="btn-outline" style="padding:8px 12px;">Open Live Jobs</a>
                <button onclick="exportReport()" class="btn-primary" style="padding:8px 12px;">Export Report</button>
            </div>
            <div style="font-size:13px; color:#64748b;">Quick actions</div>
        </div>

        <!-- LIVE DISPATCH MONITOR - Real-time job tracking and status updates -->
        <div id="live" class="live-card" style="background: white; border-radius: 14px; padding: 18px; border: 1px solid #e2e8f0; box-shadow: 0 6px 12px -6px rgba(2,6,23,0.06); margin-bottom:18px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; gap:12px;">
                <div style="display:flex; align-items:center; gap:12px;">
                    <h3 style="margin:0;">Live Dispatch Monitor</h3>
                    <span class="pulse-dot" title="Live"></span>
                </div>
                <div style="display:flex; gap:8px; align-items:center;">
                    <div style="font-size:13px; color:#64748b;">Filter:</div>
                    <button class="btn-outline" onclick="setLiveFilter('all')">All</button>
                    <button class="btn-outline" onclick="setLiveFilter('pending')">Pending</button>
                    <button class="btn-outline" onclick="setLiveFilter('sos')">Urgent</button>
                </div>
            </div>

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; gap:12px;">
                <div style="display:flex; gap:8px; align-items:center; font-size:13px; color:#64748b;">
                    <span class="status-badge status-pending">Pending</span>
                    <span class="status-badge status-accepted">Accepted</span>
                    <span class="status-badge status-fixing">Fixing</span>
                    <span class="status-badge status-completed">Completed</span>
                </div>
                <div style="font-size:13px; color:#94a3b8;">Click a row to open job details</div>
            </div>

            <div class="live-table">
                <table style="width:100%; border-collapse:collapse; text-align:left;">
                    <thead>
                        <tr style="color: #94a3b8; font-size: 12px; border-bottom: 2px solid #f1f5f9;">
                            <th style="padding: 12px;">STATUS</th>
                            <th>OWNER</th>
                            <th>MECHANIC</th>
                            <th>SERVICE</th>
                            <th>LAST UPDATE</th>
                            <th>ACTION</th>
                        </tr>
                    </thead>
                    <tbody id="live-body">
                        <tr id="live-empty-row"><td colspan="6" style="padding:18px; color:#64748b; text-align:center;">Loading live jobs...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div style="display:flex; gap:18px; margin-top:34px; flex-wrap:wrap;">
            <div style="flex:1 1 60%; min-width:320px;">
                <h3 style="margin-bottom:12px;">Recent System Activity</h3>
                <div id="activity-panel" style="background:white; border-radius:12px; border:1px solid #e2e8f0; padding:12px; min-height:120px;">
                    <% if (recentJobs_value.length === 0) { %>
                        <div style="color:#64748b; text-align:center; padding:30px;">No recent activity to show.</div>
                    <% } else { %>
                        <ul id="activity-list" style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;">
                            <% recentJobs_value.slice(0,8).forEach(job => { %>
                                <li style="display:flex; justify-content:space-between; align-items:center; gap:12px; padding:8px 6px; border-bottom:1px solid #f1f5f9;">
                                    <div>
                                        <div style="font-weight:700;">#<%= job.id %> — <%= job.service_type %></div>
                                        <div style="font-size:13px; color:#64748b;"><%= job.owner_name %> • <span style="text-transform:capitalize;"><%= job.status %></span></div>
                                    </div>
                                    <div style="font-size:12px; color:#94a3b8;"><%= new Date(job.updated_at).toLocaleString() %></div>
                                </li>
                            <% }) %>
                        </ul>
                    <% } %>
                </div>
            </div>

            <div style="flex:1 1 36%; min-width:260px;">
                <h3 style="margin-bottom:12px;">Mechanic Verification Queue</h3>
                <div style="background:white; border-radius:12px; border:1px solid #e2e8f0; padding:12px;">
                    <div style="max-height:280px; overflow:auto; display:flex; flex-direction:column; gap:8px;">
                        <% if (pending_value.length === 0) { %>
                            <div style="color:#64748b; text-align:center; padding:20px;">No pending verifications.</div>
                        <% } else { %>
                            <% pending_value.slice(0,6).forEach(mech => { %>
                                <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; padding:8px; border-bottom:1px solid #f1f5f9;">
                                    <div>
                                        <div style="font-weight:700;"><%= mech.full_name %></div>
                                        <div style="font-size:12px; color:#64748b;"><%= mech.email %></div>
                                    </div>
                                    <div style="display:flex; gap:8px; align-items:center;">
                                        <button data-user-id="<%= mech.id %>" onclick="approveMech(this.dataset.userId)" class="btn-primary" style="padding:6px 10px; background:#22c55e;">Verify</button>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <h3 style="margin-top: 50px; margin-bottom: 20px;">Mechanic Verification Queue</h3>
        <div style="background: white; border-radius: 20px; overflow: hidden; border: 1px solid #e2e8f0;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <tr style="background: #f1f5f9; font-size: 12px; color: #64748b;">
                    <th style="padding: 15px;">MECHANIC</th>
                    <th>GARAGE</th>
                    <th>EXPERTISE</th>
                    <th>ACTION</th>
                </tr>
                <% pending_value.forEach(mech => { %>
                    <tr style="border-bottom: 1px solid #f1f5f9; font-size: 14px;">
                        <td style="padding: 15px;">
                            <strong><%= mech.full_name %></strong><br>
                            <span style="font-size: 12px; color: #64748b;"><%= mech.email %></span>
                        </td>
                        <td><%= mech.garage_name || 'Not set' %></td>
                        <td><%= mech.expertise || 'General Service' %></td>
                        <td>
                            <button data-user-id="<%= mech.id %>" onclick="approveMech(this.dataset.userId)" class="btn-primary" style="padding: 8px 15px; font-size: 12px; background: #22c55e;">
                                Verify Mechanic
                            </button>
                        </td>
                    </tr>
                <% }) %>
            </table>
        </div>
    </div>

    <script>
        lucide.createIcons();
        const socket = io();
        const dashboardDataEl = document.getElementById('dashboard-page-data');
        const dashboardData = dashboardDataEl ? JSON.parse(dashboardDataEl.textContent || '{}') : { revenue: 0, jobTotal: 0, liveJobs: [] };

        // Toggle system maintenance mode on/off
        async function toggleMaintenance(val) {
            await fetch('/api/admin/toggle-maintenance', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ isEnabled: val })
            });
            location.reload();
        }

        // Approve and verify a mechanic account
        async function approveMech(id) {
            const res = await fetch('/api/admin/approve-mechanic', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ userId: id })
            });
            if (res.ok) {
                location.reload();
            }
        }

        // View detailed job log and dispatch history
        function viewJobLog(jobId) {
            window.open(`/admin/job/${jobId}`, '_blank');
        }

        // Quick export (client-side trigger - server should handle actual export)
        function exportReport() {
            window.open('/admin/export-report', '_blank');
        }

        function refreshLiveFeed() {
            location.reload();
        }

        // Live table behavior: filtering and clickable rows
        let liveFilter = 'all';
        function setLiveFilter(val) {
            liveFilter = val;
            const rows = Array.from(document.querySelectorAll('#live-body .live-row'));
            rows.forEach(r => {
                const status = r.querySelector('.status-badge').textContent.trim().toLowerCase();
                if (val === 'all') r.style.display = '';
                else if (val === 'sos') {
                    // urgent jobs flagged via SOS in server side as 'sos_active' or status 'sos'
                    if (r.dataset.sos === 'true' || status.includes('sos')) r.style.display = '';
                    else r.style.display = 'none';
                } else {
                    r.style.display = status.includes(val) ? '' : 'none';
                }
            });
        }

        function openJob(id) {
            window.location = `/admin/job/${id}`;
        }

        function createLiveJobRow(job) {
            const row = document.createElement('tr');
            row.id = `job-row-${job.id}`;
            row.className = 'live-row';
            row.dataset.jobId = job.id;
            row.style.borderBottom = '1px solid #f1f5f9';
            row.style.fontSize = '14px';
            row.style.cursor = 'pointer';
            row.addEventListener('click', () => openJob(job.id));

            const statusCell = document.createElement('td');
            statusCell.style.padding = '12px';
            const statusBadge = document.createElement('span');
            statusBadge.className = `status-badge status-${job.status}`;
            statusBadge.innerText = String(job.status || '').replaceAll('_', ' ');
            statusCell.appendChild(statusBadge);

            const ownerCell = document.createElement('td');
            ownerCell.innerHTML = `<strong>${job.owner_name || ''}</strong>`;

            const mechCell = document.createElement('td');
            const mechWrap = document.createElement('div');
            mechWrap.style.display = 'flex';
            mechWrap.style.alignItems = 'center';
            mechWrap.style.gap = '8px';
            const mechDot = document.createElement('div');
            mechDot.className = `mechanic-indicator ${job.mechanic_online ? 'online' : 'offline'}`;
            const mechName = document.createElement('span');
            mechName.innerText = job.mechanic_name || 'Searching...';
            mechWrap.appendChild(mechDot);
            mechWrap.appendChild(mechName);
            mechCell.appendChild(mechWrap);

            const serviceCell = document.createElement('td');
            serviceCell.innerText = job.service_type || '';

            const timeCell = document.createElement('td');
            timeCell.className = 'update-time';
            timeCell.style.color = '#94a3b8';
            timeCell.style.fontSize = '12px';
            timeCell.innerText = job.updated_at ? new Date(job.updated_at).toLocaleTimeString() : '--';

            const actionCell = document.createElement('td');
            const btn = document.createElement('button');
            btn.className = 'job-log-btn';
            btn.type = 'button';
            btn.innerHTML = '<i data-lucide="external-link" size="16"></i>';
            btn.addEventListener('click', (event) => {
                event.stopPropagation();
                viewJobLog(job.id);
            });
            actionCell.appendChild(btn);

            row.appendChild(statusCell);
            row.appendChild(ownerCell);
            row.appendChild(mechCell);
            row.appendChild(serviceCell);
            row.appendChild(timeCell);
            row.appendChild(actionCell);
            return row;
        }

        function renderLiveJobs() {
            const tbody = document.getElementById('live-body');
            if (!tbody) return;

            tbody.innerHTML = '';

            if (!Array.isArray(dashboardData.liveJobs) || dashboardData.liveJobs.length === 0) {
                const emptyRow = document.createElement('tr');
                emptyRow.id = 'live-empty-row';
                const emptyCell = document.createElement('td');
                emptyCell.colSpan = 6;
                emptyCell.style.padding = '18px';
                emptyCell.style.color = '#64748b';
                emptyCell.style.textAlign = 'center';
                emptyCell.innerText = 'No live jobs right now.';
                emptyRow.appendChild(emptyCell);
                tbody.appendChild(emptyRow);
                return;
            }

            dashboardData.liveJobs.forEach((job) => {
                tbody.appendChild(createLiveJobRow(job));
            });
            lucide.createIcons();
        }

        socket.on('admin_live_update', (data) => {
            if (!data || !data.jobId) return;

            const row = document.getElementById(`job-row-${data.jobId}`);

            if (row) {
                const statusCell = row.querySelector('.status-badge');
                if (statusCell) {
                    statusCell.innerText = String(data.status || '').toUpperCase();
                    statusCell.className = `status-badge status-${data.status}`;
                }

                row.style.background = '#fff7ed';
                setTimeout(() => {
                    row.style.background = 'transparent';
                }, 2000);

                const updateTimeCell = row.querySelector('.update-time');
                if (updateTimeCell) {
                    updateTimeCell.innerText = new Date().toLocaleTimeString();
                }
            } else {
                refreshLiveFeed();
            }

            try {
                new Audio('https://assets.mixkit.co/active_storage/sfx/2357/2357-preview.mp3').play();
            } catch (err) {
                console.warn('Notification sound failed:', err);
            }
        });

        // Sparklines: lightweight polyline renderer
        function drawSpark(id, points, color) {
            const svg = document.getElementById(id);
            if (!svg || !points || points.length === 0) return;
            const w = 100, h = 28;
            const max = Math.max(...points), min = Math.min(...points);
            const scaleX = (i) => (i/(points.length-1))*w;
            const scaleY = (v) => {
                if (max === min) return h/2;
                return h - ((v-min)/(max-min) * h);
            }
            const path = points.map((p,i)=> `${i===0?'M':'L'} ${scaleX(i)} ${scaleY(p)}`).join(' ');
            svg.innerHTML = `<path d="${path}" fill="none" stroke="${color}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`;
        }

        // Simple trend formatter
        function formatTrend(elId, val) {
            const el = document.getElementById(elId);
            if (!el) return;
            if (val > 0) el.innerHTML = `<span class=\"kpi-trend up\">+${val}%</span>`;
            else if (val < 0) el.innerHTML = `<span class=\"kpi-trend down\">${val}%</span>`;
            else el.innerHTML = `<span class=\"kpi-trend\">—</span>`;
        }

        // Hydrate sparklines and trends from server-side minimal arrays (or generate placeholders)
        (function hydrateKPIs(){
            try {
                const revCurrent = Number(dashboardData.revenue || 0);
                const jobCurrent = Number(dashboardData.jobTotal || 0);
                const revSeries = [0, 0, 0, 0, 0, 0, revCurrent];
                const jobSeries = [0, 1, 2, 1, 3, 2, jobCurrent];

                drawSpark('rev-spark', revSeries, '#16a34a');
                drawSpark('jobs-spark', jobSeries, '#3b82f6');

                // Compute a simple percent delta against the first value
                const revDelta = (()=>{ const first=revSeries[0]||1; const last=revSeries[revSeries.length-1]||0; return Math.round(((last-first)/Math.max(1,first))*100); })();
                const jobsDelta = (()=>{ const first=jobSeries[0]||1; const last=jobSeries[jobSeries.length-1]||0; return Math.round(((last-first)/Math.max(1,first))*100); })();

                formatTrend('rev-trend', revDelta);
                formatTrend('jobs-trend', jobsDelta);
            } catch (e) { /* non-critical */ }
        })();

        renderLiveJobs();
    </script>
</body>
</html>