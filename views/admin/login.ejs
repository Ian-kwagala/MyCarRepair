<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><title>Admin Portal | MyCarRepair</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body.auth-page {
            min-height: 100vh;
            background:
                radial-gradient(circle at top left, rgba(249, 115, 22, 0.22), transparent 28%),
                radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.18), transparent 32%),
                linear-gradient(180deg, #0f172a 0%, #111827 100%);
        }

        .auth-card {
            box-shadow: 0 24px 80px rgba(15, 23, 42, 0.42);
            border: 1px solid rgba(255, 255, 255, 0.08);
            overflow: hidden;
            animation: popIn 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .auth-header {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%) !important;
            position: relative;
        }

        .auth-header::after {
            content: '';
            position: absolute;
            inset: auto -20px -20px auto;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(249, 115, 22, 0.22), transparent 70%);
            pointer-events: none;
        }

        .label-mini {
            letter-spacing: 0.18em;
            font-size: 10px;
            text-transform: uppercase;
            color: #94a3b8;
            font-weight: 900;
        }

        .input-row {
            border-radius: 14px;
            transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
        }

        .input-row:focus-within {
            transform: translateY(-1px);
            border-color: rgba(59, 130, 246, 0.45);
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.12);
        }

        .btn-primary {
            transition: transform 180ms ease, box-shadow 180ms ease;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 30px rgba(51, 65, 85, 0.26);
        }

        @keyframes popIn {
            from { opacity: 0; transform: translateY(16px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
    </style>
</head>
<body class="auth-page" style="background: #0f172a;">
    <div class="auth-card animate-pop-in">
        <div class="auth-header" style="background: #334155;">
            <i data-lucide="shield-check" size="48" style="margin-bottom: 10px; color: #f8fafc;"></i>
            <h2 style="margin-bottom: 6px;">Staff Portal</h2>
            <p style="opacity: 0.68; margin: 0;">Management & Governance Access</p>
        </div>
        <form action="/auth/admin-login" method="POST" style="padding: 30px;">
            <span class="label-mini">Admin Email</span>
            <div class="input-row">
                <i data-lucide="mail"></i>
                <input type="email" name="email" required>
            </div>
            <span class="label-mini">Secret Key</span>
            <div class="input-row">
                <i data-lucide="lock"></i>
                <input type="password" name="password" required>
            </div>
            <button type="submit" class="btn-primary" style="width: 100%; background: linear-gradient(135deg, #334155, #0f172a);">Enter Dashboard</button>
        </form>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>